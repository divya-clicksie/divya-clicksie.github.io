---
const currentYear = new Date().getFullYear();
const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';
const alexaURL = 'https://www.amazon.com/Clicksie-LLC-Nubo-Baby-Tracker/dp/B0FJ2N8XKB';
const instagramURL = 'https://www.instagram.com/nubo_baby_tracker';
const youtubeURL = 'https://www.youtube.com/@NuboBabyTracker';
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Nubo Baby Tracker Home">
          <img src="/images/nubo-logo.svg" alt="nubo" width="80" height="24" />
        </a>
        <p class="footer-tagline">Care with Confidence</p>
      </div>

      <div class="footer-columns">
        <div class="footer-col">
          <h3>Product</h3>
          <ul>
            <li><a href="#how-it-works">How It Works</a></li>
            <li><a href="#features">Features</a></li>
            <li><a href="#reviews">Reviews</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3>Get Nubo</h3>
          <ul>
            <li><a href={amazonURL} target="_blank" rel="noopener noreferrer">Buy on Amazon</a></li>
            <li><a href={appStoreURL} target="_blank" rel="noopener noreferrer">App Store (Free)</a></li>
            <li><a href={playStoreURL} target="_blank" rel="noopener noreferrer">Google Play (Free)</a></li>
            <li><a href={alexaURL} target="_blank" rel="noopener noreferrer">Alexa Skill (Free)</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3>Support</h3>
          <ul>
            <li><a href="/faq/">FAQ</a></li>
            <li><a href="/contact/">Contact</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="/privacy-policy/">Privacy Policy</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3>Follow Us</h3>
          <div class="footer-social">
            <a href={instagramURL} target="_blank" rel="noopener noreferrer" aria-label="Follow Nubo on Instagram" class="social-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
              <span>Instagram</span>
            </a>
            <a href={youtubeURL} target="_blank" rel="noopener noreferrer" aria-label="Follow Nubo on YouTube" class="social-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"></path>
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
              </svg>
              <span>YouTube</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-disclaimer">
        Nubo is not a medical device and is not intended to diagnose, treat, cure, or prevent medical conditions.
      </p>
      <p class="footer-legal">
        Designed by Clicksie in USA &middot; &copy; {currentYear} Clicksie LLC
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #fafafa;
    padding: 4rem 0 2.5rem;
    border-top: 1px solid #eee;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    padding-bottom: 3rem;
  }

  .footer-brand {
    flex-shrink: 0;
  }

  .footer-logo {
    display: block;
    margin-bottom: 0.75rem;
  }

  .footer-logo img {
    height: 22px;
    width: auto;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: #888;
  }

  .footer-columns {
    display: flex;
    gap: 4rem;
  }

  .footer-col h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #999;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
  }

  .footer-col li + li {
    margin-top: 0.6rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: #555;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: #13BCC3;
  }

  .footer-social {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #555;
    transition: color 0.2s;
  }

  .social-link:hover {
    color: #13BCC3;
  }

  .social-link svg {
    flex-shrink: 0;
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .footer-disclaimer {
    font-size: 0.75rem;
    color: #bbb;
    margin-bottom: 0.5rem;
  }

  .footer-legal {
    font-size: 0.75rem;
    color: #999;
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: 2.5rem;
    }

    .footer-columns {
      flex-direction: column;
      gap: 2rem;
    }
  }
</style>
