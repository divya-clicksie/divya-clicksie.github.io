---
interface Props {
  lead: string;
  support?: string;
  variant?: 'band' | 'kicker' | 'plain';
  align?: 'center' | 'start';
}

const { lead, support, variant = 'band', align = 'center' } = Astro.props;
---

<aside class={`attention-line attention-line-${variant} attention-line-${align}`}>
  <div class="container">
    <p class="attention-line-lead">{lead}</p>
    {support && <p class="attention-line-support">{support}</p>}
  </div>
</aside>

<style>
  .attention-line { padding: 2.25rem 0; }
  .attention-line-center .container { text-align: center; }
  .attention-line-start .container { text-align: left; }
  .attention-line-lead {
    font-weight: 700;
    font-size: clamp(1.25rem, 2.6vw, 1.75rem);
    line-height: 1.25;
    color: var(--color-brand-dark);
    margin: 0;
  }
  .attention-line-support {
    margin: 0.5rem auto 0;
    max-width: 46rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 1.0625rem;
  }
  .attention-line-start .attention-line-support { margin-left: 0; margin-right: 0; }

  /* Band: soft brand-tinted strip used inside product pages */
  .attention-line-band {
    background: var(--color-brand-light);
    border-top: 1px solid rgba(19, 188, 195, 0.18);
    border-bottom: 1px solid rgba(19, 188, 195, 0.18);
  }

  /* Kicker: quiet, borderless line used as a closing note */
  .attention-line-kicker { padding: 1.5rem 0 0; }
  .attention-line-kicker .attention-line-lead {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--color-text-primary, #1d1d1f);
  }

  /* Plain: no background, used inside an existing section */
  .attention-line-plain { background: transparent; }

  @media (max-width: 640px) {
    .attention-line { padding: 1.75rem 0; }
  }
</style>
