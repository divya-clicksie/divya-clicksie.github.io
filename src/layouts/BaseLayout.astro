---
interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const siteName = 'Nubo Baby Tracker';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Preload LCP image on the home page -->
    {Astro.url.pathname === '/' && (
      <link rel="preload" as="image" href="/images/hero.webp" fetchpriority="high" />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Fonts – self-hosted to eliminate the Google Fonts critical chain -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/quicksand-latin.woff2"
      crossorigin
    />
  </head>
  <body>
    <slot />
    <script>
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.addEventListener('pageshow', () => {
        requestAnimationFrame(() => window.scrollTo(0, 0));
      });
    </script>
  </body>
</html>

<style is:global>  /* ── Self-hosted Quicksand ── */
  @font-face {
    font-family: 'Quicksand';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('/fonts/quicksand-latin.woff2') format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Quicksand';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('/fonts/quicksand-latin-ext.woff2') format('woff2');
    unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
  }
  @font-face {
    font-family: 'Quicksand';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('/fonts/quicksand-vietnamese.woff2') format('woff2');
    unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;
  }
  /* ── Reset ─────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* Fallback font tuned to match Quicksand metrics, preventing CLS on font swap */
  @font-face {
    font-family: 'Quicksand Fallback';
    src: local('Arial');
    size-adjust: 96%;
    ascent-override: 95%;
    descent-override: 24%;
    line-gap-override: 0%;
  }

  html {
    font-family: 'Quicksand', 'Quicksand Fallback', system-ui, -apple-system, sans-serif;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  body {
    color: #1d1d1f;
    background: #ffffff;
    line-height: 1.6;
    overflow-x: hidden;
  }

  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; text-decoration: none; }
  button { cursor: pointer; font: inherit; }

  /* ── Container ─────────────────────── */
  .container {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Design tokens ─────────────────── */
  :root {
    --color-brand: #13BCC3;
    --color-brand-dark: #0ea5ab;
    --color-brand-light: #e6f9fa;
    --color-text: #1d1d1f;
    --color-text-secondary: #6e6e73;
    --color-bg-warm: #faf8f5;
    --color-bg-soft: #f5f5f7;
    --radius-xl: 24px;
    --radius-2xl: 32px;
  }

  /* ── Shared UI classes ─────────────── */
  .overline {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 0.75rem;
  }

  .section-intro {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-intro h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .section-sub {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 540px;
    margin: 1rem auto 0;
    line-height: 1.6;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.25rem;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    background: var(--color-brand);
    border-radius: 100px;
    border: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    letter-spacing: -0.01em;
  }

  .btn-primary:hover {
    background: var(--color-brand-dark);
    transform: scale(1.04);
    box-shadow: 0 8px 30px rgba(19, 188, 195, 0.3);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.25rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brand);
    background: transparent;
    border: 2px solid var(--color-brand);
    border-radius: 100px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-ghost:hover {
    background: var(--color-brand-light);
  }

  .btn-lg {
    padding: 1.125rem 3rem;
    font-size: 1.125rem;
  }

  .text-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-brand);
    transition: color 0.2s;
  }

  .text-link:hover {
    color: var(--color-brand-dark);
  }

  /* ── Page hero (shared by inner pages) ── */
  .page-hero {
    padding: 10rem 0 4rem;
    background: linear-gradient(170deg, #f0fafa 0%, #fff 60%);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .page-hero-sub {
    margin-top: 1rem;
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .hero-link {
    color: var(--color-brand);
    font-weight: 600;
    transition: color 0.2s;
  }

  .hero-link:hover {
    color: var(--color-brand-dark);
  }
</style>
