---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  datePublished: string;
  dateModified: string;
  author: string;
  heroImage?: string;
  ogImage?: string;
  tags?: string[];
}

const {
  title,
  description,
  datePublished,
  dateModified,
  author,
  heroImage,
  ogImage,
  tags = [],
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": author },
  "publisher": {
    "@type": "Organization",
    "name": "Nubo",
    "url": "https://www.nubotracker.com",
  },
  "datePublished": datePublished,
  "dateModified": dateModified,
  ...(heroImage ? { "image": `https://www.nubotracker.com${heroImage}` } : {}),
};
---

<BaseLayout
  title={`${title} | Nubo Baby Tracker`}
  description={description}
  ogImage={ogImage || heroImage || '/images/og-default.jpg'}
  ogType="article"
  jsonLd={jsonLd}
>
  <Header />
  <main>
    <article class="guide">
      <header class="guide-hero">
        <div class="container">
          <p class="overline">Guide</p>
          <h1>{title}</h1>
          <p class="guide-meta">
            <time datetime={datePublished}>{new Date(datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <span class="meta-sep">&middot;</span>
            <span>{author}</span>
          </p>
        </div>
      </header>

      {heroImage && (
        <div class="guide-hero-image container">
          <img src={heroImage} alt={title} width="1120" height="560" loading="eager" />
        </div>
      )}

      <div class="guide-body container">
        <div class="prose">
          <slot />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .guide-hero {
    padding: 10rem 0 3rem;
    background: linear-gradient(170deg, #f0fafa 0%, #fff 60%);
    text-align: center;
  }

  .guide-hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    max-width: 720px;
    margin: 0 auto;
  }

  .guide-meta {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .meta-sep {
    margin: 0 0.5rem;
    color: #ccc;
  }

  .guide-hero-image {
    margin-top: -1rem;
    margin-bottom: 3rem;
  }

  .guide-hero-image img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  .guide-body {
    padding: 3rem 0 6rem;
  }

  .prose {
    max-width: 720px;
    margin: 0 auto;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .prose :global(h3) {
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .prose :global(p) {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 0.4rem;
  }

  .prose :global(a) {
    color: var(--color-brand);
    font-weight: 600;
    transition: color 0.2s;
  }

  .prose :global(a:hover) {
    color: var(--color-brand-dark);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-brand);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: var(--color-bg-soft);
    border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
    font-style: italic;
    color: #555;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(img) {
    border-radius: var(--radius-xl);
    margin: 1.5rem 0;
  }

  @media (max-width: 768px) {
    .guide-hero { padding: 8rem 0 2.5rem; }
    .guide-hero-image img { border-radius: 16px; }
  }
</style>
