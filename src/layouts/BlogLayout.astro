---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  datePublished: string;
  dateModified: string;
  author: string;
  category: string;
  heroImage?: string;
  ogImage?: string;
  tags?: string[];
}

const {
  title,
  description,
  datePublished,
  dateModified,
  author,
  category,
  heroImage,
  ogImage,
  tags = [],
} = Astro.props;

const categoryLabels: Record<string, string> = {
  sleep: 'Sleep',
  feeding: 'Feeding',
  tracking: 'Tracking',
  caregiver: 'Caregiver',
  privacy: 'Privacy',
  product: 'Product',
  gifts: 'Gifts',
};

const categoryNextSteps: Record<string, { eyebrow: string; title: string; copy: string; href: string; cta: string }> = {
  sleep: {
    eyebrow: 'Track sleep without the scramble',
    title: 'See how Nubo keeps nights simple.',
    copy: 'Tap the device at the crib, catch up by voice later, and keep every caregiver on the same timeline.',
    href: '/device/',
    cta: 'View the device',
  },
  feeding: {
    eyebrow: 'For feeds, pumping, and bottles',
    title: 'Start with the free app.',
    copy: 'Log nursing, bottles, pumping, diapers, growth, allergens, and notes without ads or a credit card.',
    href: '/app/',
    cta: 'Explore the app',
  },
  tracking: {
    eyebrow: 'Make the routine easier',
    title: 'Choose the setup that fits your household.',
    copy: 'Compare the free app, Premium, and the Nubo device by speed, privacy, and caregiver needs.',
    href: '/pricing/',
    cta: 'See pricing',
  },
  caregiver: {
    eyebrow: 'Shared care, one timeline',
    title: 'Coordinate with partners, grandparents, nannies, and daycare.',
    copy: 'Nubo keeps handoffs clear, and the device grants Premium to each phone that connects.',
    href: '/caregivers/',
    cta: 'See caregiver sync',
  },
  privacy: {
    eyebrow: 'Private by design',
    title: 'Read the plain-English privacy promise.',
    copy: 'Voice runs on your phone, backups use your iCloud or Google Drive, and there are no ads or tracking scripts on the site.',
    href: '/privacy/',
    cta: 'Read privacy overview',
  },
  product: {
    eyebrow: 'How Nubo works',
    title: 'One baby timeline, several ways to log.',
    copy: 'Use the device, voice catch-up, Quick Log, and caregiver sync together without rebuilding your routine.',
    href: '/how-it-works/',
    cta: 'See how it works',
  },
  gifts: {
    eyebrow: 'A practical baby gift',
    title: 'Give the button parents actually use.',
    copy: 'The Nubo device is useful before the hospital bag, during newborn nights, and across the next baby too.',
    href: '/gift/',
    cta: 'See the gift page',
  },
};

const nextStep = categoryNextSteps[category] || categoryNextSteps.tracking;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": author },
  "publisher": {
    "@type": "Organization",
    "name": "Nubo",
    "url": "https://www.nubotracker.com",
  },
  "datePublished": datePublished,
  "dateModified": dateModified,
  ...(heroImage ? { "image": `https://www.nubotracker.com${heroImage}` } : {}),
};
---

<BaseLayout
  title={`${title} | Nubo Baby Tracker`}
  description={description}
  ogImage={ogImage || heroImage || '/images/nubo-instant-tracker.webp'}
  ogType="article"
  jsonLd={jsonLd}
>
  <Header />
  <main>
    <article class="blog-post">
      <header class="blog-hero">
        <div class="container">
          <a href="/blog/" class="overline blog-back">{categoryLabels[category] || category}</a>
          <h1>{title}</h1>
          <p class="blog-meta">
            <span>{author}</span>
          </p>
        </div>
      </header>

      {heroImage && (
        <div class="blog-hero-image container">
          <img src={heroImage} alt={title} width="1120" height="560" loading="eager" />
        </div>
      )}

      <div class="blog-body container">
        <div class="prose">
          <slot />
        </div>
        <aside class="article-next-step" aria-label="Recommended next step">
          <p class="article-next-step-eyebrow">{nextStep.eyebrow}</p>
          <h2>{nextStep.title}</h2>
          <p>{nextStep.copy}</p>
          <a href={nextStep.href}>{nextStep.cta}</a>
        </aside>
        <aside class="article-brand-line" aria-label="Why Nubo">
          <p class="article-brand-line-lead">Not more screen time. Better caregiving coordination.</p>
          <p class="article-brand-line-support">Nubo is built for the kind of tracking pediatric guidance can live with: private, minimal, shared, and designed to keep attention on the baby.</p>
        </aside>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-hero {
    padding: 10rem 0 3rem;
    background: linear-gradient(170deg, #f0fafa 0%, #fff 60%);
    text-align: center;
  }

  .blog-hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: 0;
    color: var(--color-text);
    max-width: 720px;
    margin: 0 auto;
  }

  .blog-back {
    display: inline-block;
    transition: color 0.2s;
  }

  .blog-back:hover {
    color: var(--color-brand-dark);
  }

  .blog-meta {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .blog-hero-image {
    margin-top: -1rem;
    margin-bottom: 3rem;
  }

  .blog-hero-image img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  .blog-body {
    padding: 3rem 0 6rem;
  }

  .prose {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0;
  }

  .prose :global(h3) {
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0;
  }

  .prose :global(p) {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 0.4rem;
  }

  .prose :global(a) {
    color: var(--color-brand);
    font-weight: 600;
    transition: color 0.2s;
  }

  .prose :global(a:hover) {
    color: var(--color-brand-dark);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-brand);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: var(--color-bg-soft);
    border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
    font-style: italic;
    color: #555;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(img) {
    border-radius: var(--radius-xl);
    margin: 1.5rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }

  .prose :global(th) {
    text-align: left;
    font-weight: 700;
    color: var(--color-text);
    padding: 0.75rem 1rem;
    border-bottom: 2px solid #e5e5e7;
    background: var(--color-bg-soft);
  }

  .prose :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e5e5e7;
    color: #444;
    line-height: 1.6;
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .article-next-step {
    max-width: 720px;
    margin: 3rem auto 0;
    padding: 2rem;
    border: 1px solid rgba(61, 179, 173, 0.22);
    border-radius: var(--radius-xl);
    background: linear-gradient(150deg, #f0fafa 0%, #fff 74%);
  }

  .article-next-step-eyebrow {
    margin-bottom: 0.65rem;
    color: var(--color-brand-dark);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-next-step h2 {
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: 0;
    color: var(--color-text);
  }

  .article-next-step p:not(.article-next-step-eyebrow) {
    margin-top: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .article-next-step a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.15rem;
    min-height: 44px;
    padding: 0.75rem 1.1rem;
    border-radius: 999px;
    background: var(--color-brand);
    color: #fff;
    font-weight: 800;
  }

  .article-next-step a:hover {
    background: var(--color-brand-dark);
  }

  .article-brand-line {
    max-width: 720px;
    margin: 1.5rem auto 0;
    padding: 0 0.25rem;
    text-align: center;
  }

  .article-brand-line-lead {
    font-weight: 800;
    font-size: 1.0625rem;
    color: var(--color-brand-dark);
    margin: 0;
  }

  .article-brand-line-support {
    margin: 0.5rem auto 0;
    color: var(--color-text-secondary);
    line-height: 1.65;
    font-size: 0.9375rem;
  }

  @media (max-width: 768px) {
    .blog-hero { padding: 8rem 0 2.5rem; }
    .blog-hero-image img { border-radius: 16px; }

    .article-next-step {
      margin-top: 2.25rem;
      padding: 1.5rem;
      border-radius: 18px;
    }

    .prose :global(table) {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }
</style>
