---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpeedComparison from '../components/SpeedComparison.astro';

const title = 'Compare Baby Trackers | One-Tap Device vs Apps and Notes';
const description = 'Compare Nubo with paper logs, shared notes, free baby tracker apps, and sleep-focused baby apps. See when a one-tap baby tracker is worth it.';
const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: 'https://www.nubotracker.com/compare/',
  about: { '@type': 'Product', name: 'Nubo Baby Tracker' }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="page-hero compare-hero">
      <div class="container">
        <p class="overline">One-tap baby tracker comparison</p>
        <h1>The fastest way to log a feed. By the numbers.</h1>
        <p class="page-hero-sub">Nubo is the one-tap baby tracker for night feeds, hands-full moments, and multi-caregiver households. It is built for the moments when tracking needs to be fast, shared, and less phone-heavy.</p>
        <div class="hero-actions-inline"><a href="/pricing/" class="btn-primary">See pricing</a><a href={amazonURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Buy on Amazon</a></div>
      </div>
    </section>

    <SpeedComparison expanded compact />

    <section class="use-case-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Compare by use case</p><h2>Honest answers for the tracker you already know.</h2></div>
        <div class="comparison-grid">
          <article><h2>Vs. paper diary</h2><p>Paper is fine for quiet, undistracted moments. It loses when you need charts, exports, caregiver sync, or a record that travels to appointments.</p></article>
          <article><h2>Vs. Apple Notes</h2><p>A shared note is flexible, but baby tracking needs timestamps, totals, growth, exports, and a way to log without typing.</p></article>
          <article><h2>Vs. free tracker apps</h2><p>Free apps can be enough for one phone-first caregiver. Nubo adds a physical baby tracker device and stronger caregiver economics when the household gets more complex.</p></article>
          <article><h2>Vs. Huckleberry</h2><p>Huckleberry is sleep-coaching software with a tracker. Nubo is tracking software with a device. They are adjacent, not identical.</p></article>
          <article><h2>Vs. hospital paper logs</h2><p>Paper logs help in the hospital. Nubo helps keep the same discipline at home after NICU follow-up, then turns that history into pediatrician-ready data.</p></article>
        </div>
      </div>
    </section>

    <section class="fit-section">
      <div class="container fit-grid">
        <div>
          <p class="overline">When the device is optional</p>
          <h2>Start with the free Nubo app.</h2>
          <ul>
            <li>One caregiver, phone always in hand, the free Nubo app is probably enough.</li>
            <li>No interest in advanced charts, exports, or Premium tools? The free Nubo app still covers everyday tracking.</li>
            <li>If tracking itself creates stress, keep it light and only log what helps.</li>
          </ul>
        </div>
        <div>
          <p class="overline">When the device wins clearly</p>
          <h2>The messy real-life cases.</h2>
          <ul>
            <li>Multiple caregivers, especially nanny, grandparents, doulas, or daycare.</li>
            <li>Night feeds, hands-full changes, and phone-across-the-room moments.</li>
            <li>Privacy-conscious families who want local-first data and no ads.</li>
            <li>Families planning for another baby, where the device keeps working.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="truth-band">
      <div class="container truth-inner">
        <div><p class="overline">The honest answer</p><h2>Choose the simplest tracker that your household will actually use.</h2></div>
        <div><p>Choose the free app if you want the lowest-friction start today. Choose the device if your partner, parents, nanny, or nighttime routine makes logging unreliable. Choose Premium if you love the app and want advanced tools without hardware.</p><a href="/pricing/" class="btn-primary">Choose your setup</a></div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .compare-hero .hero-actions-inline { justify-content: center; }
  .hero-actions-inline { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .use-case-section, .fit-section, .truth-band { padding: 6rem 0; }
  .use-case-section { background: #fff; }
  .fit-section { background: var(--color-bg-soft); }
  .truth-band { background: var(--color-bg-warm); }
  .comparison-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.5rem; }
  .comparison-grid article, .fit-grid > div { background: #fff; border: 1px solid #e8e8e8; border-radius: var(--radius-xl); padding: 1.75rem; }
  .comparison-grid h2 { font-size: 1.125rem; margin-bottom: 0.75rem; }
  .comparison-grid p, .truth-inner p, .fit-grid li { color: var(--color-text-secondary); line-height: 1.7; }
  .fit-grid, .truth-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .fit-grid h2, .truth-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .fit-grid ul { padding-left: 1.25rem; }
  .fit-grid li + li { margin-top: 0.75rem; }
  .truth-inner { align-items: center; }
  .truth-inner .btn-primary { margin-top: 1.5rem; }
  @media (max-width: 1120px) { .comparison-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) { .fit-grid, .truth-inner { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .use-case-section, .fit-section, .truth-band { padding: 4rem 0; } .comparison-grid { grid-template-columns: 1fr; } }
</style>