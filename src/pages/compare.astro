---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Compare Baby Trackers | Nubo vs Apps, Paper, and Notes';
const description = 'Compare Nubo with paper logs, shared notes, free baby tracker apps, and sleep-focused baby apps. See when a physical button is worth it.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: 'https://www.nubotracker.com/compare/',
  about: { '@type': 'Product', name: 'Nubo Baby Tracker' }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="overline">Compare</p>
        <h1>When is Nubo the better baby tracker?</h1>
        <p class="page-hero-sub">If you have your phone in hand all day and one caregiver, a free app can be enough. Nubo wins when tracking has to survive dark rooms, full hands, and multiple caregivers.</p>
      </div>
    </section>

    <section class="compare-main">
      <div class="container">
        <div class="comparison-grid">
          <article><h2>Nubo vs paper notebook</h2><p>Paper can be fast in the moment, but it cannot sync to another caregiver, show patterns, export data, or carry logs to the pediatrician without retyping.</p></article>
          <article><h2>Nubo vs Apple Notes</h2><p>A shared note is flexible, but baby tracking needs timestamps, totals, charts, exports, reminders, and a way to log when nobody wants to type.</p></article>
          <article><h2>Nubo vs free tracker apps</h2><p>Free apps can be enough for one phone-first caregiver. Nubo adds a physical button and multi-caregiver Premium value when the household gets more complicated.</p></article>
          <article><h2>Nubo vs sleep coaching apps</h2><p>Sleep coaching apps are strongest when sleep prediction is the main goal. Nubo is for whole-day tracking with a device that makes logging easier.</p></article>
        </div>

        <div class="table-wrap">
          <table>
            <thead><tr><th>Need</th><th>Free app</th><th>Paper or notes</th><th>Nubo</th></tr></thead>
            <tbody>
              <tr><td>Fast phone-in-hand logging</td><td>Strong</td><td>Good</td><td>Strong</td></tr>
              <tr><td>Hands-full logging</td><td>Weak</td><td>Weak</td><td>Strong</td></tr>
              <tr><td>Multiple caregivers</td><td>Varies</td><td>Weak</td><td>Strong</td></tr>
              <tr><td>Pediatrician exports</td><td>Varies</td><td>Weak</td><td>Strong</td></tr>
              <tr><td>No hardware purchase</td><td>Strong</td><td>Strong</td><td>Use the free Nubo app</td></tr>
              <tr><td>Giftable setup</td><td>Weak</td><td>Weak</td><td>Strong</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="truth-band">
      <div class="container truth-inner">
        <div><p class="overline">The honest answer</p><h2>Nubo is not for every family. It is for the moments apps miss.</h2></div>
        <div><p>Choose the free app if you want the lowest-friction start today. Choose the device if your partner, parents, nanny, or nighttime routine makes logging unreliable. Choose Premium if you love the app and want the advanced features without hardware.</p><a href="/pricing/" class="btn-primary">Choose your setup</a></div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .compare-main, .truth-band { padding: 6rem 0; }
  .compare-main { background: #fff; }
  .truth-band { background: var(--color-bg-warm); }
  .comparison-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 3rem; }
  .comparison-grid article { background: var(--color-bg-soft); border-radius: var(--radius-xl); padding: 1.75rem; }
  .comparison-grid h2 { font-size: 1.125rem; margin-bottom: 0.75rem; }
  .comparison-grid p, .truth-inner p { color: var(--color-text-secondary); line-height: 1.7; }
  .table-wrap { overflow-x: auto; }
  table { width: 100%; min-width: 680px; border-collapse: collapse; background: #fff; border: 1px solid #eee; border-radius: var(--radius-xl); overflow: hidden; }
  th, td { padding: 1rem; text-align: left; border-bottom: 1px solid #eee; }
  th { color: var(--color-text-secondary); font-size: 0.8125rem; text-transform: uppercase; }
  td:last-child { color: var(--color-brand-dark); font-weight: 700; }
  .truth-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .truth-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; }
  .truth-inner .btn-primary { margin-top: 1.5rem; }
  @media (max-width: 980px) { .comparison-grid { grid-template-columns: 1fr 1fr; } .truth-inner { grid-template-columns: 1fr; gap: 2rem; } }
  @media (max-width: 640px) { .compare-main, .truth-band { padding: 4rem 0; } .comparison-grid { grid-template-columns: 1fr; } }
</style>