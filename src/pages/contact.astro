---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Contact Us | Nubo Baby Tracker';
const description = 'Get in touch with the Nubo team. Questions about your device, the app, or your order? We typically respond within one business day.';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Nubo",
  "description": description,
  "url": "https://www.nubotracker.com/contact/",
  "publisher": {
    "@type": "Organization",
    "name": "Clicksie LLC",
    "url": "https://www.nubotracker.com",
    "email": "support@clicksie.io"
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="overline">We're here to help</p>
        <h1>Contact Us</h1>
        <p class="page-hero-sub">
          Have a question about Nubo? We'd love to hear from you.
        </p>
      </div>
    </section>

    <section class="contact-content">
      <div class="container contact-inner">

        <div class="contact-card contact-card-primary">
          <div class="contact-card-icon" aria-hidden="true">✉</div>
          <h2>Email us</h2>
          <p>The fastest way to reach us. We typically respond within one business day.</p>
          <a href="mailto:support@clicksie.io" class="contact-email">support@clicksie.io</a>
        </div>

        <div class="contact-grid">
          <div class="contact-card">
            <h3>Device or app issues</h3>
            <p>
              Having trouble with your Nubo device or the companion app?
              Include your device serial number (on the back of Nubo) and
              a brief description of the issue. Screenshots help too.
            </p>
          </div>

          <div class="contact-card">
            <h3>Order questions</h3>
            <p>
              For order status, shipping, or returns, please contact
              Amazon directly through your order page. Nubo is sold
              and fulfilled by Amazon.
            </p>
          </div>

          <div class="contact-card">
            <h3>Press and partnerships</h3>
            <p>
              Interested in reviewing Nubo or exploring a partnership?
              Email us with a brief description and we'll get back to you.
            </p>
          </div>

          <div class="contact-card">
            <h3>Privacy and data</h3>
            <p>
              Questions about your data or our privacy practices?
              See our <a href="/privacy-policy/">privacy policy</a> or email us directly.
            </p>
          </div>
        </div>

        <div class="contact-faq">
          <h2>Looking for quick answers?</h2>
          <p>
            Many common questions are answered on our <a href="/faq/">FAQ page</a>.
            Check there first for the fastest help.
          </p>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>


<style>
  .contact-content {
    padding: 4rem 0 6rem;
  }

  .contact-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .contact-card-primary {
    text-align: center;
    background: var(--color-bg-soft);
    border-radius: var(--radius-xl);
    padding: 3rem;
    margin-bottom: 2.5rem;
  }

  .contact-card-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .contact-card-primary h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .contact-card-primary p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .contact-email {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #ffffff !important;
    background: var(--color-brand);
    border-radius: 100px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-email:hover {
    color: #ffffff !important;
    background: var(--color-brand-dark);
    transform: scale(1.04);
    box-shadow: 0 8px 30px rgba(19, 188, 195, 0.3);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .contact-card {
    background: var(--color-bg-soft);
    border-radius: var(--radius-xl);
    padding: 2rem;
  }

  .contact-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .contact-card p {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.7;
  }

  .contact-card a:not(.contact-email) {
    color: var(--color-brand);
    font-weight: 600;
    transition: color 0.2s;
  }

  .contact-card a:hover {
    color: var(--color-brand-dark);
  }

  .contact-faq {
    text-align: center;
    padding: 2.5rem;
    border-top: 1px solid #eee;
  }

  .contact-faq h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .contact-faq p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .contact-faq a {
    color: var(--color-brand);
    font-weight: 600;
    transition: color 0.2s;
  }

  .contact-faq a:hover {
    color: var(--color-brand-dark);
  }

  @media (max-width: 768px) {
    .page-hero { padding: 8rem 0 3rem; }
    .contact-card-primary { padding: 2rem; }
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
