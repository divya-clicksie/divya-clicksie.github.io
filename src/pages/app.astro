---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Nubo App | Free Baby Tracker for Feeds, Sleep, and Diapers';
const description = 'Download the free Nubo baby tracker app. Track feeds, sleep, diapers, growth, vaccines, allergens, milestones, and caregiver handoffs with voice catch-up and privacy-first storage.';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';

const screenshots = [
  ['One-touch logging', '/images/appscreens/01_onetouch.webp', 'Fast logs when your phone is already in hand.'],
  ['Voice catch-up', '/images/appscreens/02_voicelogging.webp', 'Say what happened and Nubo files it at the right time.'],
  ['Caregiver timeline', '/images/appscreens/03_collaboration.webp', 'Everyone sees the same day without check-in texts.'],
  ['Live Activities', '/images/appscreens/04_liveactivities.webp', 'Glance from the lock screen during active care.'],
  ['Growth charts', '/images/appscreens/05_growth.webp', 'Bring real numbers to the pediatrician visit.'],
  ['Midnight Ember', '/images/appscreens/06_midnightember.webp', 'A softer night mode for 3 a.m. logging.'],
  ['Privacy controls', '/images/appscreens/07_privacy.webp', 'Local-first storage with encrypted sharing and backups.'],
  ['Voice notes', '/images/appscreens/08_voicenotes.webp', 'Capture details you do not want to type.'],
  ['Allergen SafeStart', '/images/appscreens/09_allergensafestart.webp', 'Track first foods and reactions with structure.']
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Nubo Baby Tracker',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'HealthApplication',
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  installUrl: appStoreURL
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="app-hero">
      <div class="container app-hero-inner">
        <div>
          <p class="overline">Free Nubo app</p>
          <h1>A free baby tracker that does not punish you for needing help.</h1>
          <p>Track the essentials, invite caregivers, catch up by voice, and keep the baby's history private. Start with the app today, then add Premium or the device only when it makes sense.</p>
          <div class="hero-actions-inline">
            <a href={appStoreURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Download on App Store</a>
            <a href={playStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Get it on Google Play</a>
          </div>
        </div>
        <picture>
          <source srcset="/images/appscreens/01_onetouch.webp" type="image/webp" />
          <img src="/images/appscreens/01_onetouch.png" alt="Nubo app one-touch tracking screen" width="642" height="1389" />
        </picture>
      </div>
    </section>

    <section class="free-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Free forever</p><h2>The free tier is real.</h2><p class="section-sub">No ads, no time limits, no credit card, and no artificial cap on the basics parents need every day.</p></div>
        <div class="feature-grid">
          <article><h3>Full routine tracking</h3><p>Feeds, sleep, diapers, growth, vaccines, allergens, milestones, medication, and notes.</p></article>
          <article><h3>Voice catch-up</h3><p>Say "she napped from 1 to 2:30" and Nubo turns it into a structured log.</p></article>
          <article><h3>Caregiver sync</h3><p>Invite partner, grandparents, nanny, or anyone helping with the baby.</p></article>
          <article><h3>Private by design</h3><p>Voice logging runs on your phone. Backups go to your own iCloud or Google Drive.</p></article>
        </div>
      </div>
    </section>

    <section class="screens-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Screenshots by outcome</p><h2>Everything has a job.</h2></div>
        <div class="screens-grid">
          {screenshots.map(([label, src, copy]) => (
            <figure>
              <img src={src} alt={`Nubo app screenshot: ${label}`} width="642" height="1389" loading="lazy" decoding="async" />
              <figcaption><strong>{label}</strong><span>{copy}</span></figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="upgrade-section">
      <div class="container upgrade-inner">
        <div>
          <p class="overline">Optional upgrade</p>
          <h2>Premium adds advanced tools. The device adds a faster way to log.</h2>
          <p>Premium is for app-only caregivers who want reminders, Alexa, Live Activities, exports, advanced growth metrics, and Premium modes. The device is for families who need one-button logging and Premium for every caregiver.</p>
          <a href="/pricing/" class="btn-primary">Compare setups</a>
        </div>
        <img src="/images/nubo-device-hand.webp" alt="Hand pressing the Nubo baby tracker device" width="640" height="400" />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .app-hero { padding: 10rem 0 5rem; background: linear-gradient(170deg, #f0fafa 0%, #fff 60%); overflow: hidden; }
  .app-hero-inner, .upgrade-inner { display: grid; grid-template-columns: 1fr 0.75fr; gap: 4rem; align-items: center; }
  .app-hero h1 { font-size: clamp(2.35rem, 5vw, 4rem); line-height: 1.08; margin-bottom: 1rem; }
  .app-hero p, .feature-grid p, .upgrade-inner p, figcaption span { color: var(--color-text-secondary); line-height: 1.7; }
  .app-hero picture { display: flex; justify-content: center; }
  .app-hero img { max-height: 620px; width: auto; border-radius: 30px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.14); }
  .hero-actions-inline { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .free-section, .screens-section, .upgrade-section { padding: 6rem 0; }
  .free-section, .upgrade-section { background: #fff; }
  .screens-section { background: var(--color-bg-soft); }
  .feature-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .feature-grid article { background: var(--color-bg-soft); border-radius: var(--radius-xl); padding: 1.75rem; }
  .feature-grid h3 { font-size: 1.125rem; margin-bottom: 0.5rem; }
  .screens-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .screens-grid figure { background: #fff; border-radius: var(--radius-xl); padding: 1rem; text-align: center; }
  .screens-grid img { max-height: 420px; width: auto; margin: 0 auto; border-radius: 24px; box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12); }
  figcaption { display: flex; flex-direction: column; gap: 0.375rem; margin-top: 1rem; }
  .upgrade-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .upgrade-inner img { border-radius: var(--radius-xl); box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08); }
  .upgrade-inner .btn-primary { margin-top: 1.5rem; }
  @media (max-width: 980px) { .app-hero-inner, .upgrade-inner { grid-template-columns: 1fr; } .feature-grid, .screens-grid { grid-template-columns: 1fr 1fr; } .app-hero picture { order: -1; } }
  @media (max-width: 640px) { .app-hero { padding-top: 8rem; } .free-section, .screens-section, .upgrade-section { padding: 4rem 0; } .feature-grid, .screens-grid { grid-template-columns: 1fr; } .app-hero img { max-height: 480px; } }
</style>