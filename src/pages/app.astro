---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Nubo App | Free Baby Tracker with Voice Catch-Up';
const description = 'Download the free Nubo baby tracker app for quick logs, voice catch-up, caregiver sync, growth, vaccines, allergens, milestones, and private iOS and Android sharing.';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';

const screenshots = [
  ['Free, unlimited quick logging', '/images/appscreens/01_onetouch.webp', 'Nubo app screenshot showing colorful quick-log cards for sleep, nursing, formula, milk, and diaper'],
  ['Voice catch-up', '/images/appscreens/02_voicelogging.webp', 'Nubo app screenshot showing voice logging for catching up on missed baby events'],
  ['Caregiver timeline', '/images/appscreens/03_collaboration.webp', 'Nubo app screenshot showing caregiver collaboration and shared baby timeline'],
  ['Live Activities', '/images/appscreens/04_liveactivities.webp', 'Nubo app screenshot showing Live Activities for active baby care'],
  ['Growth charts', '/images/appscreens/05_growth.webp', 'Nubo app screenshot showing baby growth charts'],
  ['Midnight Ember', '/images/appscreens/06_midnightember.webp', 'Nubo app screenshot showing Midnight Ember night mode'],
  ['Privacy controls', '/images/appscreens/07_privacy.webp', 'Nubo app screenshot showing privacy controls and sharing settings'],
  ['Voice notes', '/images/appscreens/08_voicenotes.webp', 'Nubo app screenshot showing voice notes for baby care details'],
  ['Allergen SafeStart', '/images/appscreens/09_allergensafestart.webp', 'Nubo app screenshot showing allergen introduction tracking']
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Nubo Baby Tracker',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'HealthApplication',
  url: 'https://www.nubotracker.com/app/',
  description,
  image: 'https://www.nubotracker.com/images/appscreens/01_onetouch.webp',
  featureList: [
    'One-tap quick logs for routine baby care',
    'On-device voice catch-up in the app',
    'Feeds, sleep, diapers, growth, vaccines, allergens, milestones, medication, and notes',
    'Unlimited caregivers across iOS and Android',
    'End-to-end encrypted caregiver sharing',
    'Offline mode and private cloud backup'
  ],
  offers: [
    { '@type': 'Offer', name: 'Nubo free app', price: '0', priceCurrency: 'USD', url: appStoreURL },
    { '@type': 'Offer', name: 'Nubo Premium', price: '39.99', priceCurrency: 'USD', url: appStoreURL }
  ],
  installUrl: [appStoreURL, playStoreURL],
  downloadUrl: [appStoreURL, playStoreURL]
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="app-hero">
      <div class="container app-hero-inner">
        <div>
          <p class="overline">Free baby tracker app for iPhone and Android</p>
          <h1>Baby tracking that catches up when newborn life gets messy.</h1>
          <p>Log feeds, sleep, diapers, medicine, growth, and notes with quick taps. Remembered something later? Say it in plain English. Sharing care? Keep every caregiver on the same timeline.</p>
          <div class="hero-store-links" aria-label="Download Nubo app">
            <a href={appStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/appstore-badge.webp" alt="Download on the App Store" width="160" height="56" /></a>
            <a href={playStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/playstore-badge.webp" alt="Get it on Google Play" width="160" height="56" /></a>
          </div>
          <p class="hero-trust">No ads. No credit card. No trial countdown.</p>
        </div>
        <div class="app-carousel" data-app-carousel aria-roledescription="carousel" aria-label="Nubo app screenshots">
          <div class="app-carousel-stage">
            {screenshots.map(([label, src, alt], index) => (
              <figure class:list={['app-slide', { 'is-active': index === 0 }]} data-app-slide hidden={index !== 0}>
                <img src={src} alt={alt} width="642" height="1389" loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
              </figure>
            ))}
          </div>
          <div class="app-carousel-controls" aria-label="App screenshot controls">
            <button type="button" class="app-carousel-btn" data-app-prev aria-label="Previous app screenshot"></button>
            <div class="app-carousel-dots" role="tablist" aria-label="Choose app screenshot">
              {screenshots.map(([label], index) => (
                <button type="button" class:list={['app-carousel-dot', { 'is-active': index === 0 }]} data-app-dot={index} role="tab" aria-selected={index === 0 ? 'true' : 'false'} aria-label={`Show ${label}`}></button>
              ))}
            </div>
            <button type="button" class="app-carousel-btn" data-app-next aria-label="Next app screenshot"></button>
          </div>
        </div>
      </div>
    </section>

    <section class="timeline-section">
      <div class="container">
        <div class="section-intro"><p class="overline">One baby timeline</p><h2>However care happens.</h2><p class="section-sub">Baby care rarely happens in perfect app-sized moments. Nubo helps keep the day accurate whether you log right away, remember later, or hand care to someone else.</p></div>
        <div class="moment-grid">
          <article><h3>Log now</h3><p>Use quick app buttons for feeds, sleep, diapers, medicine, growth, notes, and more when your phone is already in hand.</p></article>
          <article><h3>Catch up later</h3><p>Say what happened in plain English, like "gave 3 oz around noon" or "wet diaper after the nap," and Nubo turns it into structured logs.</p></article>
          <article><h3>Share the day</h3><p>Invite caregivers across iPhone and Android so everyone works from the same baby timeline.</p></article>
        </div>
      </div>
    </section>

    <section class="free-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Free forever</p><h2>Start free and actually use it free.</h2><p class="section-sub">Nubo's free app includes the core tracking families use every day, without ads, a credit card, a trial countdown, or artificial caps on the basics.</p></div>
        <div class="feature-grid">
          <article><h3>Core logs</h3><p>Feeds, sleep, diapers, medicine, growth, vaccines, allergens, milestones, and notes.</p></article>
          <article><h3>Voice catch-up</h3><p>Speak naturally when you remember something later, and Nubo files it into the timeline.</p></article>
          <article><h3>Caregiver sync</h3><p>Invite a partner, grandparent, nanny, or anyone helping with the baby across iOS and Android.</p></article>
          <article><h3>Offline and private storage</h3><p>Use Nubo offline, then back up to your own iCloud or Google Drive when you choose.</p></article>
        </div>
      </div>
    </section>

    <div class="mid-cta-strip">
      <div class="container mid-cta-inner">
        <p>Free on iPhone and Android, no credit card, no ads, no trial countdown.</p>
        <div class="mid-cta-links">
          <a href={appStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/appstore-badge.webp" alt="Download on the App Store" width="160" height="56" loading="lazy" /></a>
          <a href={playStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/playstore-badge.webp" alt="Get it on Google Play" width="160" height="56" loading="lazy" /></a>
        </div>
      </div>
    </div>

    <section class="privacy-app-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Privacy details</p><h2>Privacy details you can check.</h2><p class="section-sub">Nubo is not built around ads or selling baby data. In-app voice runs on your phone, backups use your cloud, and sharing stays between invited caregivers.</p></div>
        <div class="privacy-points">
          <article><h3>In-app voice stays on your phone</h3><p>In-app voice logging runs on-device, so audio is not sent to Nubo servers for transcription. Alexa logging uses Amazon's Alexa systems.</p></article>
          <article><h3>Your backup, your cloud</h3><p>Backups use your own iCloud or Google Drive instead of a Nubo account database.</p></article>
          <article><h3>End-to-end encrypted sharing</h3><p>Shared care works across iOS and Android while staying between the people you invite, with no ads and no selling baby data.</p></article>
        </div>
        <p class="section-route"><a href="/privacy/" class="text-link">Read the privacy overview &rarr;</a></p>
      </div>
    </section>

    <section class="upgrade-section">
      <div class="container upgrade-inner">
        <div>
          <p class="overline">Optional upgrade</p>
          <h2>Start with the app. Add the device when your phone becomes the bottleneck.</h2>
          <p>Many families begin with the free app. Add Premium for advanced app tools, or add the device when opening your phone becomes the part that keeps failing.</p>
          <div class="upgrade-cards">
            <article><h3>Premium app</h3><p>Best for reminders, exports, Alexa, Live Activities, Care Vault, private pumping, and advanced views.</p><a href="/pricing/#plans">See Premium details</a></article>
            <article><h3>Nubo device</h3><p>Best when night feeds, hands-full changes, or caregiver routines make phone logging unreliable.</p><a href="/device/">See device details</a></article>
          </div>
          <div class="hero-actions-inline"><a href="#app-downloads" class="btn-primary">Download the free app</a><a href="/device/" class="btn-ghost">See the quick-log device</a></div>
        </div>
        <img src="/images/nubo-instant-tracker-900.webp" alt="Hand pressing the Nubo instant tracker beside a sleeping baby" width="900" height="900" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="proof-section" id="app-downloads">
      <div class="container proof-inner">
        <div>
          <p class="overline">Start with the app</p>
          <h2>Download free. Keep the day easier to trust.</h2>
          <p>Start with quick logs, voice catch-up, caregiver sync, offline mode, and private storage. Premium and the device are optional paths for families who need more.</p>
        </div>
        <div class="store-panel" aria-label="Download Nubo app">
          <p><strong>Free on iOS and Android</strong><span>No credit card. No ads. No time limit.</span></p>
          <div class="store-links">
            <a href={appStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/appstore-badge.webp" alt="Download on the App Store" width="160" height="56" loading="lazy" /></a>
            <a href={playStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/playstore-badge.webp" alt="Get it on Google Play" width="160" height="56" loading="lazy" /></a>
          </div>
          <a href="/pricing/" class="text-link">See all setup options &rarr;</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const carousel = document.querySelector('[data-app-carousel]');

  if (carousel) {
    const slides = Array.from(carousel.querySelectorAll('[data-app-slide]'));
    const dots = Array.from(carousel.querySelectorAll('[data-app-dot]'));
    const prev = carousel.querySelector('[data-app-prev]');
    const next = carousel.querySelector('[data-app-next]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeIndex = 0;
    let rotation;

    const showSlide = (nextIndex) => {
      activeIndex = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, index) => {
        const active = index === activeIndex;
        slide.hidden = !active;
        slide.classList.toggle('is-active', active);
      });

      dots.forEach((dot, index) => {
        const active = index === activeIndex;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    };

    const stopRotation = () => {
      if (rotation) window.clearInterval(rotation);
      rotation = undefined;
    };

    const startRotation = () => {
      if (prefersReducedMotion || rotation) return;
      rotation = window.setInterval(() => showSlide(activeIndex + 1), 4500);
    };

    prev?.addEventListener('click', () => {
      stopRotation();
      showSlide(activeIndex - 1);
    });

    next?.addEventListener('click', () => {
      stopRotation();
      showSlide(activeIndex + 1);
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopRotation();
        showSlide(index);
      });
    });

    carousel.addEventListener('mouseenter', stopRotation);
    carousel.addEventListener('focusin', stopRotation);
    carousel.addEventListener('mouseleave', startRotation);
    startRotation();
  }
</script>

<style>
  .app-hero { padding: 10rem 0 5rem; background: linear-gradient(170deg, #f0fafa 0%, #fff 60%); overflow: hidden; }
  .app-hero-inner, .upgrade-inner, .proof-inner { display: grid; grid-template-columns: 1fr 0.75fr; gap: 4rem; align-items: center; }
  .app-hero h1 { font-size: clamp(2.35rem, 5vw, 4rem); line-height: 1.08; margin-bottom: 1rem; }
  .app-hero p, .moment-grid p, .feature-grid p, .upgrade-inner p, .privacy-points p, .proof-inner p { color: var(--color-text-secondary); line-height: 1.7; }
  .hero-actions-inline { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .hero-store-links { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; margin-top: 2rem; }
  .hero-store-links img { height: 52px; width: auto; border-radius: 0; box-shadow: none; }
  .hero-trust { margin-top: 1rem; font-weight: 800; color: var(--color-brand-dark) !important; }
  .app-carousel { justify-self: center; width: min(100%, 360px); }
  .app-carousel-stage { position: relative; display: grid; place-items: center; min-height: 620px; }
  .app-slide { margin: 0; text-align: center; }
  .app-slide img { display: block; max-height: 620px; width: auto; max-width: 100%; border-radius: 30px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.14); }
  .app-carousel-controls { display: grid; grid-template-columns: 2.25rem 1fr 2.25rem; align-items: center; gap: 0.75rem; margin-top: 1rem; }
  .app-carousel-btn { position: relative; width: 2.25rem; height: 2.25rem; border: 1px solid rgba(61, 179, 173, 0.28); border-radius: 999px; background: #fff; color: var(--color-brand-dark); cursor: pointer; }
  .app-carousel-btn::before { content: ""; position: absolute; top: 50%; left: 50%; width: 0.5rem; height: 0.5rem; border-top: 2px solid currentColor; border-right: 2px solid currentColor; }
  .app-carousel-btn[data-app-prev]::before { transform: translate(-42%, -50%) rotate(225deg); }
  .app-carousel-btn[data-app-next]::before { transform: translate(-58%, -50%) rotate(45deg); }
  .app-carousel-dots { display: flex; align-items: center; justify-content: center; gap: 0.45rem; }
  .app-carousel-dot { width: 0.55rem; height: 0.55rem; border: 0; border-radius: 999px; background: #c9e9ea; cursor: pointer; }
  .app-carousel-dot.is-active { width: 1.4rem; background: var(--color-brand); }
  .timeline-section, .free-section, .privacy-app-section, .upgrade-section, .proof-section { padding: 6rem 0; }
  .proof-section { scroll-margin-top: 1rem; }
  .free-section, .upgrade-section { background: #fff; }
  .timeline-section, .privacy-app-section, .proof-section { background: var(--color-bg-soft); }
  .moment-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .moment-grid article { background: #fff; border-radius: var(--radius-xl); padding: 1.75rem; }
  .moment-grid h3 { font-size: 1.125rem; margin-bottom: 0.5rem; }
  .feature-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .feature-grid article { background: var(--color-bg-soft); border-radius: var(--radius-xl); padding: 1.75rem; }
  .feature-grid h3 { font-size: 1.125rem; margin-bottom: 0.5rem; }
  .feature-grid a { color: var(--color-brand-dark); font-weight: 700; }
  .upgrade-inner h2, .proof-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .privacy-points, .upgrade-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .privacy-points article, .upgrade-cards article { background: #fff; border-radius: var(--radius-xl); padding: 1.5rem; }
  .upgrade-cards { grid-template-columns: repeat(3, 1fr); margin-top: 1.5rem; }
  .upgrade-cards article { background: var(--color-bg-soft); }
  .privacy-points h3, .upgrade-cards h3 { font-size: 1.1rem; margin-bottom: 0.55rem; color: var(--color-text); }
  .upgrade-cards a { display: inline-flex; margin-top: 0.75rem; color: var(--color-brand-dark); font-weight: 700; }
  .upgrade-inner img { border-radius: var(--radius-xl); box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08); }
  .store-panel { display: grid; gap: 1rem; justify-self: end; width: min(100%, 420px); padding: 1.75rem; border-radius: var(--radius-xl); background: #fff; box-shadow: 0 18px 44px rgba(0, 0, 0, 0.07); }
  .store-panel p { margin: 0; display: grid; gap: 0.35rem; }
  .store-panel strong { color: var(--color-text); font-size: 1.15rem; }
  .store-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .store-links img { height: 48px; width: auto; }
  .mid-cta-strip { background: var(--color-brand-light); padding: 2.5rem 0; border-top: 1px solid rgba(61, 179, 173, 0.15); border-bottom: 1px solid rgba(61, 179, 173, 0.15); }
  .mid-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .mid-cta-inner p { margin: 0; font-weight: 700; color: var(--color-text); font-size: 1.05rem; }
  .mid-cta-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .mid-cta-links img { height: 44px; width: auto; }
  @media (max-width: 980px) { .app-hero { padding: 8rem 0 4rem; } .app-hero-inner, .upgrade-inner, .proof-inner { grid-template-columns: 1fr; } .moment-grid, .feature-grid, .privacy-points, .upgrade-cards { grid-template-columns: 1fr 1fr; } .store-panel { justify-self: stretch; width: 100%; } .mid-cta-inner { flex-direction: column; align-items: flex-start; } }
  @media (max-width: 640px) { .app-hero { padding-top: 7rem; } .timeline-section, .free-section, .privacy-app-section, .upgrade-section, .proof-section { padding: 4rem 0; } .moment-grid, .feature-grid, .privacy-points, .upgrade-cards { grid-template-columns: 1fr; } .app-carousel { width: min(100%, 300px); } .app-carousel-stage { min-height: 520px; } .app-slide img { max-height: 480px; } .hero-store-links img { height: 46px; } .store-links a, .store-links img { width: 100%; height: auto; } .mid-cta-links img { height: 40px; } }
</style>
