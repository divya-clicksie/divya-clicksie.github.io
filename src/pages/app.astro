---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Nubo App | Free One-Tap Baby Tracker for iOS and Android';
const description = 'Download the free Nubo baby tracker app for one-tap logging, voice catch-up, caregiver sync, growth, vaccines, allergens, milestones, and private iOS and Android sharing.';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';

const screenshots = [
  ['One-touch logging', '/images/appscreens/01_onetouch.webp', 'Fast logs when your phone is already in hand.'],
  ['Voice catch-up', '/images/appscreens/02_voicelogging.webp', 'Speak naturally and Nubo files it at the right time.'],
  ['Caregiver timeline', '/images/appscreens/03_collaboration.webp', 'Everyone sees the same day without check-in texts.'],
  ['Live Activities', '/images/appscreens/04_liveactivities.webp', 'Glance from the lock screen during active care.'],
  ['Growth charts', '/images/appscreens/05_growth.webp', 'Bring real numbers to the pediatrician visit.'],
  ['Midnight Ember', '/images/appscreens/06_midnightember.webp', 'A softer night mode for 3 a.m. logging.'],
  ['Privacy controls', '/images/appscreens/07_privacy.webp', 'Local-first storage with encrypted sharing and backups.'],
  ['Voice notes', '/images/appscreens/08_voicenotes.webp', 'Capture details you do not want to type.'],
  ['Allergen SafeStart', '/images/appscreens/09_allergensafestart.webp', 'Track first foods and reactions with structure.']
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Nubo Baby Tracker',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'HealthApplication',
  url: 'https://www.nubotracker.com/app/',
  description,
  image: 'https://www.nubotracker.com/images/appscreens/01_onetouch.webp',
  featureList: [
    'One-tap quick logs for routine baby care',
    'On-device voice catch-up in the app',
    'Feeds, sleep, diapers, growth, vaccines, allergens, milestones, medication, and notes',
    'Unlimited caregivers across iOS and Android',
    'End-to-end encrypted caregiver sharing',
    'Offline mode and private cloud backup'
  ],
  offers: [
    { '@type': 'Offer', name: 'Nubo free app', price: '0', priceCurrency: 'USD', url: appStoreURL },
    { '@type': 'Offer', name: 'Nubo Premium', price: '39.99', priceCurrency: 'USD', url: appStoreURL }
  ],
  installUrl: [appStoreURL, playStoreURL],
  downloadUrl: [appStoreURL, playStoreURL]
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="app-hero">
      <div class="container app-hero-inner">
        <div>
          <p class="overline">Free one-tap baby tracker</p>
          <h1>A free baby tracker built for shared care.</h1>
          <p>Track the essentials, invite caregivers, catch up by voice, and keep the baby's history private. Start with the app today, then add Premium or the device only when it makes sense.</p>
          <div class="hero-actions-inline">
            <a href={appStoreURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Download on App Store</a>
            <a href={playStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Get it on Google Play</a>
          </div>
        </div>
        <img src="/images/appscreens/01_onetouch.webp" alt="Nubo app one-touch tracking screen" width="642" height="1389" />
      </div>
    </section>

    <section class="free-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Free forever</p><h2>The free tier is real.</h2><p class="section-sub">No ads, no time limits, no credit card, and no artificial cap on the basics parents need every day.</p></div>
        <div class="feature-grid">
          <article><h3>Full routine tracking</h3><p>Feeds, sleep, diapers, growth, vaccines, allergens, milestones, medication, and notes.</p></article>
          <article><h3>Voice catch-up</h3><p>Say "baby slept at 1 and woke up 10 minutes ago" and Nubo turns it into a structured log.</p></article>
          <article><h3>Unlimited caregiver sync</h3><p>Invite partner, grandparents, nanny, or anyone helping with the baby across iOS and Android. See how it works on the <a href="/caregivers/">caregiver page</a>.</p></article>
          <article><h3>Private by design</h3><p>Voice logging runs on your phone. Backups go to your own iCloud or Google Drive. Read the <a href="/privacy/">privacy overview</a>.</p></article>
        </div>
      </div>
    </section>

    <section class="voice-section">
      <div class="container voice-inner">
        <div>
          <p class="overline">Voice catch-up</p>
          <h2>For the log you remembered later.</h2>
          <p>Nubo voice is built for normal parent memory and real speech patterns. Say what happened in plain English, including fuzzy times, and Nubo turns it into a structured event in the right place.</p>
          <div class="voice-example" aria-label="Example voice log">
            <span>&ldquo;Baby slept at 1 and woke up 10 minutes ago.&rdquo;</span>
            <strong>Nubo infers the likely 1 a.m. or 1 p.m. start, then anchors 10 minutes ago to the moment you spoke.</strong>
          </div>
          <p class="voice-note">No need to twist your commands to fit a rigid voice system. Voice catch-up is free and runs on your phone.</p>
        </div>
        <img src="/images/appscreens/02_voicelogging.webp" alt="Nubo app voice logging screen" width="642" height="1389" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="caregiver-app-section">
      <div class="container caregiver-app-inner">
        <img src="/images/caregiver-hub.webp" alt="Nubo device syncing baby tracking data with multiple caregiver phones" width="970" height="600" loading="lazy" decoding="async" />
        <div>
          <p class="overline">Caregiver sync</p>
          <h2>Shared tracking works in the free app too.</h2>
          <p>Invite a partner, grandparent, nanny, or anyone helping with the baby, whether they use an iPhone or Android phone. Everyone sees the same day without turning handoff into a thread of check-in texts.</p>
          <p>Caregiver sharing is end-to-end encrypted, so shared tracking can work across Apple and Google ecosystems while keeping the baby's timeline private to the people you invite.</p>
          <p>The device adds one-button logging and Premium for active caregivers, but the shared timeline starts with the free app.</p>
          <a href="/caregivers/" class="text-link">See caregiver sync &rarr;</a>
        </div>
      </div>
    </section>

    <section class="privacy-app-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Privacy promise</p><h2>The baby's history belongs to the family.</h2><p class="section-sub">Nubo is designed around private baby care, not ads or data resale.</p></div>
        <div class="privacy-points">
          <article><h3>In-app voice stays on your phone</h3><p>In-app voice logging runs on-device, so audio is not sent to Nubo servers for transcription. Alexa logging uses Amazon's Alexa systems.</p></article>
          <article><h3>Your backup, your cloud</h3><p>Backups use your own iCloud or Google Drive instead of a Nubo account database.</p></article>
          <article><h3>End-to-end encrypted sharing</h3><p>Shared care works across iOS and Android while staying between the people you invite, with no ads and no selling baby data.</p></article>
        </div>
        <p class="section-route"><a href="/privacy/" class="text-link">Read the privacy overview &rarr;</a></p>
      </div>
    </section>

    <section class="screens-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Screenshots by outcome</p><h2>Everything has a job.</h2></div>
        <div class="screens-grid">
          {screenshots.map(([label, src, copy]) => (
            <figure>
              <img src={src} alt={`Nubo app screenshot: ${label}`} width="642" height="1389" loading="lazy" decoding="async" />
              <figcaption><strong>{label}</strong><span>{copy}</span></figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="upgrade-section">
      <div class="container upgrade-inner">
        <div>
          <p class="overline">Optional upgrade</p>
          <h2>Premium adds advanced tools. The device adds a faster way to log.</h2>
          <p>Premium is for app-first families who want reminders, Alexa, Live Activities, exports, advanced growth metrics, Premium modes, and a private pumping tracker. It is managed by the App Store or Google Play account that buys it, while the device can grant Premium to separate caregiver accounts.</p>
          <div class="upgrade-cards">
            <article><h3>Private pumping</h3><p>Milk output is your body data. It is not in the shared baby log, not in caregiver sync, and not visible to partners, nannies, grandparents, or other collaborators.</p><a href="/blog/privacy/pumping-tracker-private-data/">Read the privacy guide</a></article>
            <article><h3>Premium app</h3><p>Best when one primary app account needs reminders, exports, Live Activities, advanced metrics, Alexa, and Premium modes.</p></article>
            <article><h3>Nubo device</h3><p>Best when even unlocking your phone is too much, or when non-family caregivers need Premium too.</p></article>
          </div>
          <div class="hero-actions-inline"><a href="/pricing/" class="btn-primary">Compare setups</a><a href="/device/" class="btn-ghost">See what the device adds</a></div>
        </div>
        <img src="/images/nubo-instant-tracker-900.webp" alt="Hand pressing the Nubo instant tracker beside a sleeping baby" width="900" height="900" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="proof-section" id="app-downloads">
      <div class="container proof-inner">
        <div>
          <p class="overline">Start with the app</p>
          <h2>Download free. Upgrade only when the routine asks for it.</h2>
          <p>The app is the foundation: free tracking, free voice catch-up, free caregiver sync, and private storage. Premium and the device are optional paths for families who need more.</p>
        </div>
        <div class="store-panel" aria-label="Download Nubo app">
          <p><strong>Free on iOS and Android</strong><span>No credit card. No ads. No time limit.</span></p>
          <div class="store-links">
            <a href={appStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/appstore-badge.webp" alt="Download on the App Store" width="160" height="56" loading="lazy" /></a>
            <a href={playStoreURL} target="_blank" rel="noopener noreferrer"><img src="/images/playstore-badge.webp" alt="Get it on Google Play" width="160" height="56" loading="lazy" /></a>
          </div>
          <a href="/pricing/" class="text-link">See all setup options &rarr;</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .app-hero { padding: 10rem 0 5rem; background: linear-gradient(170deg, #f0fafa 0%, #fff 60%); overflow: hidden; }
  .app-hero-inner, .upgrade-inner, .voice-inner, .caregiver-app-inner, .proof-inner { display: grid; grid-template-columns: 1fr 0.75fr; gap: 4rem; align-items: center; }
  .app-hero h1 { font-size: clamp(2.35rem, 5vw, 4rem); line-height: 1.08; margin-bottom: 1rem; }
  .app-hero p, .feature-grid p, .upgrade-inner p, .voice-inner p, .caregiver-app-inner p, .privacy-points p, .proof-inner p, figcaption span { color: var(--color-text-secondary); line-height: 1.7; }
  .app-hero-inner > img { justify-self: center; }
  .app-hero img { max-height: 620px; width: auto; border-radius: 30px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.14); }
  .hero-actions-inline { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .free-section, .voice-section, .caregiver-app-section, .privacy-app-section, .screens-section, .upgrade-section, .proof-section { padding: 6rem 0; }
  .proof-section { scroll-margin-top: 1rem; }
  .free-section, .caregiver-app-section, .upgrade-section { background: #fff; }
  .voice-section, .privacy-app-section, .screens-section, .proof-section { background: var(--color-bg-soft); }
  .feature-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .feature-grid article { background: var(--color-bg-soft); border-radius: var(--radius-xl); padding: 1.75rem; }
  .feature-grid h3 { font-size: 1.125rem; margin-bottom: 0.5rem; }
  .feature-grid a { color: var(--color-brand-dark); font-weight: 700; }
  .voice-inner h2, .caregiver-app-inner h2, .upgrade-inner h2, .proof-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .voice-inner img { max-height: 560px; width: auto; justify-self: center; border-radius: 28px; box-shadow: 0 16px 44px rgba(0, 0, 0, 0.12); }
  .voice-example { display: grid; gap: 0.5rem; margin: 1.5rem 0 0.75rem; padding: 1.25rem; border-radius: 18px; background: #fff; border: 1px solid rgba(61, 179, 173, 0.18); }
  .voice-example span { color: var(--color-text); font-size: 1.15rem; font-weight: 800; }
  .voice-example strong { color: var(--color-brand-dark); }
  .voice-note { font-size: 0.9rem; font-weight: 700; color: var(--color-brand-dark) !important; }
  .caregiver-app-inner img { width: 100%; border-radius: var(--radius-xl); box-shadow: 0 18px 44px rgba(0, 0, 0, 0.08); }
  .privacy-points, .upgrade-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .privacy-points article, .upgrade-cards article { background: #fff; border-radius: var(--radius-xl); padding: 1.5rem; }
  .upgrade-cards { grid-template-columns: repeat(3, 1fr); margin-top: 1.5rem; }
  .upgrade-cards article { background: var(--color-bg-soft); }
  .privacy-points h3, .upgrade-cards h3 { font-size: 1.1rem; margin-bottom: 0.55rem; color: var(--color-text); }
  .upgrade-cards a { display: inline-flex; margin-top: 0.75rem; color: var(--color-brand-dark); font-weight: 700; }
  .section-route { margin-top: 1.5rem; text-align: center; }
  .screens-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .screens-grid figure { background: #fff; border-radius: var(--radius-xl); padding: 1rem; text-align: center; }
  .screens-grid img { height: 420px; width: auto; max-width: 100%; aspect-ratio: 642 / 1389; object-fit: contain; margin: 0 auto; border-radius: 24px; box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12); }
  figcaption { display: flex; flex-direction: column; gap: 0.375rem; margin-top: 1rem; }
  .upgrade-inner img { border-radius: var(--radius-xl); box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08); }
  .store-panel { display: grid; gap: 1rem; justify-self: end; width: min(100%, 420px); padding: 1.75rem; border-radius: var(--radius-xl); background: #fff; box-shadow: 0 18px 44px rgba(0, 0, 0, 0.07); }
  .store-panel p { margin: 0; display: grid; gap: 0.35rem; }
  .store-panel strong { color: var(--color-text); font-size: 1.15rem; }
  .store-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .store-links img { height: 48px; width: auto; }
  @media (max-width: 980px) { .app-hero-inner, .upgrade-inner, .voice-inner, .caregiver-app-inner, .proof-inner { grid-template-columns: 1fr; } .feature-grid, .screens-grid, .privacy-points, .upgrade-cards { grid-template-columns: 1fr 1fr; } .app-hero-inner > img, .voice-inner img { order: -1; } .store-panel { justify-self: stretch; width: 100%; } }
  @media (max-width: 640px) { .app-hero { padding-top: 8rem; } .free-section, .voice-section, .caregiver-app-section, .privacy-app-section, .screens-section, .upgrade-section, .proof-section { padding: 4rem 0; } .feature-grid, .screens-grid, .privacy-points, .upgrade-cards { grid-template-columns: 1fr; } .app-hero img { max-height: 480px; } .screens-grid img { height: 360px; } .store-links a, .store-links img { width: 100%; height: auto; } }
</style>