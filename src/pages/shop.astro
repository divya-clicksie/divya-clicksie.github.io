---
const target = '/device/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting to Nubo Device</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>Nubo Device</a>.</p>
  </body>
</html>