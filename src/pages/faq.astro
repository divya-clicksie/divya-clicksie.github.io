---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'FAQ | Nubo Baby Tracker | Common Questions Answered';
const description = 'Frequently asked questions about the Nubo baby activity tracker. Learn about setup, battery life, caregiver sharing, app compatibility, and more.';

const faqs = [
  {
    q: "What does Nubo track?",
    a: "Nubo tracks feedings (breast and bottle with volume), sleep, and diapers (pee and poop). Press the corresponding button on the device to log an activity. It takes about one second."
  },
  {
    q: "Do I need the app to use Nubo?",
    a: "No. The device works on its own and stores activity logs internally. The free companion app adds trends, insights, caregiver sharing, and data export. You can start using the device immediately and connect the app whenever you're ready."
  },
  {
    q: "How does Nubo sync with the app?",
    a: "Nubo syncs via Bluetooth Low Energy. When your phone is nearby, the app automatically pulls new activity data from the device. No Wi-Fi or internet connection is needed for syncing."
  },
  {
    q: "What phones are compatible?",
    a: "The Nubo app is available for iOS (iPhone) and Android. It requires Bluetooth Low Energy support, which is standard on any phone released in the last several years."
  },
  {
    q: "How long does the battery last?",
    a: "Nubo uses a standard coin cell battery (CR2032) that lasts several months with typical use. An extra battery is included in the box. No charging cables needed."
  },
  {
    q: "Is Nubo waterproof?",
    a: "Nubo is water and spill resistant. It can handle the everyday messes of life with a baby. Just wipe it clean. It is not designed for submersion."
  },
  {
    q: "Can multiple caregivers use Nubo?",
    a: "Yes. Anyone can press the buttons on the Nubo device to log activities. In the app, you can invite caregivers (partner, grandparents, nanny) so everyone sees the same activity log in real time. Nubo Premium is included free for every caregiver."
  },
  {
    q: "Is my baby's data private?",
    a: "Yes. Activity data is stored locally on your phone. Caregiver sharing uses end-to-end encryption. Backups go to your own iCloud or Google Drive. We never sell or share your information. Read our <a href=\"/privacy-policy/\">privacy policy</a> for full details."
  },
  {
    q: "Do I need to create an account?",
    a: "No account is required to use the device or app. If you want to share data with other caregivers, you can create an optional account with just an email address."
  },
  {
    q: "Where can I buy Nubo?",
    a: "Nubo is available on <a href=\"https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas\" target=\"_blank\" rel=\"noopener noreferrer\">Amazon</a>. Free shipping with Prime. The companion app is free on the App Store and Google Play."
  },
  {
    q: "What comes in the box?",
    a: "The Nubo device (with battery installed), a milk volume sticker, a magnetic mount sticker, an extra CR2032 battery, a lanyard, and setup and user guides."
  },
  {
    q: "How do I mount or carry Nubo?",
    a: "Nubo has a built-in magnet. Use the included magnetic sticker to mount it on your fridge, crib, or anywhere convenient. You can also clip it to a bag or wear it with the included lanyard."
  },
  {
    q: "Can I export my data?",
    a: "Yes. The Nubo app lets you export your baby's activity data as a PDF or CSV. This is helpful for pediatrician visits or keeping personal records."
  },
  {
    q: "Is Nubo a medical device?",
    a: "No. Nubo is a consumer wellness product designed to help parents track daily baby activities. It is not intended to diagnose, treat, cure, or prevent any medical condition. Always consult your pediatrician for medical advice."
  },
  {
    q: "How do I get help or report an issue?",
    a: "Email us at <a href=\"mailto:support@clicksie.io\">support@clicksie.io</a>. We typically respond within one business day. You can also visit our <a href=\"/contact/\">contact page</a>."
  },
  {
    q: "How do I pair Nubo with my phone?",
    a: "Open the Nubo app, tap Add Device, and hold Nubo close to your phone. The app will find it automatically via Bluetooth. The whole process takes about 30 seconds. No Wi-Fi or passwords needed."
  },
  {
    q: "How do I reset Nubo?",
    a: "Remove the battery from the back of the device, wait 10 seconds, and reinsert it. This clears the Bluetooth connection. Then re-pair in the app by tapping Add Device. Your logged data in the app is not affected."
  },
  {
    q: "Nubo isn't syncing with the app. What should I do?",
    a: "Make sure Bluetooth is enabled on your phone and Nubo is within range (about 10 feet). Try closing and reopening the app. If it still won't sync, reset the device by removing and reinserting the battery, then re-pair. If the issue persists, email <a href=\"mailto:support@clicksie.io\">support@clicksie.io</a>."
  },
  {
    q: "How do I replace the battery?",
    a: "Slide open the battery cover on the back of the device and swap in a standard CR2032 coin cell. An extra battery is included in the box. No tools needed."
  },
  {
    q: "Can I log activities manually in the app?",
    a: "Yes. Open the app and tap the + button to add any activity with a custom time. This is useful if you forgot to press the device or want to add a past event."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]*>/g, '')
    }
  }))
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="overline">Got questions?</p>
        <h1>Frequently Asked Questions</h1>
        <p class="page-hero-sub">
          Everything you need to know about Nubo. Can't find your answer?
          <a href="/contact/" class="hero-link">Reach out to us</a>.
        </p>
      </div>
    </section>

    <section class="faq-content">
      <div class="container faq-inner">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{faq.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer">
              <p set:html={faq.a} />
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="faq-cta">
      <div class="container faq-cta-inner">
        <h2>Still have questions?</h2>
        <p>We'd love to hear from you.</p>
        <a href="/contact/" class="btn-primary">Contact us</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>


<style>
  .faq-content {
    padding: 4rem 0 2rem;
  }

  .faq-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid #eee;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    cursor: pointer;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    list-style: none;
    gap: 1.5rem;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-brand);
    transition: transform 0.3s ease;
    flex-shrink: 0;
    line-height: 1;
  }

  details[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 0 1.5rem;
  }

  .faq-answer p {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.8;
  }

  .faq-answer a {
    color: var(--color-brand);
    font-weight: 600;
    transition: color 0.2s;
  }

  .faq-answer a:hover {
    color: var(--color-brand-dark);
  }

  .faq-cta {
    padding: 4rem 0 6rem;
  }

  .faq-cta-inner {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    background: var(--color-bg-soft);
    border-radius: var(--radius-xl);
    padding: 3rem;
  }

  .faq-cta-inner h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .faq-cta-inner p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .page-hero { padding: 8rem 0 3rem; }
    .faq-question { font-size: 1rem; padding: 1.25rem 0; }
    .faq-cta-inner { padding: 2rem; }
  }
</style>
