---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpeedComparison from '../components/SpeedComparison.astro';
import CaregiverEconomics from '../components/CaregiverEconomics.astro';
import PremiumFollowsDevice from '../components/PremiumFollowsDevice.astro';

const title = 'Nubo Device | One-Tap Baby Tracker for Night Feeds';
const description = 'The one-tap baby tracker for night feeds, hands-full moments, and multi-caregiver households. Log feeds, sleep, pee, and poop with a one-second button press.';

const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Nubo Baby Tracker Device',
  alternateName: ['One-tap baby tracker', 'Physical baby tracker device'],
  image: [
    'https://www.nubotracker.com/images/nubo-instant-tracker.webp',
    'https://www.nubotracker.com/images/nubo-oneclick.webp'
  ],
  description,
  sku: 'B0CJLNBG4P',
  category: 'Baby activity tracker',
  brand: { '@type': 'Brand', name: 'Nubo' },
  url: 'https://www.nubotracker.com/device/',
  featureList: [
    'One-button logging for feeds, sleep, pee, and poop',
    'Bluetooth sync with the free Nubo app',
    'Premium access refresh for phones that sync with the device',
    'Magnetic mount, lanyard, and battery included'
  ],
  offers: {
    '@type': 'Offer',
    price: '89.99',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    url: amazonURL
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.2',
    reviewCount: '32'
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="device-hero">
      <div class="container device-hero-grid">
        <div>
          <p class="overline">One-tap baby tracker</p>
          <h1>One-second baby logging, even when your phone is nowhere near you.</h1>
          <p class="hero-sub">Press once for feeding, sleep, pee, or poop. Nubo remembers the exact time, then syncs with the free app and keeps every active caregiver on Premium.</p>
          <div class="hero-actions-inline"><a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy on Amazon · $89.99</a><a href="/app/" class="btn-ghost">Use the free app first</a></div>
          <div class="trust-strip" aria-label="Nubo purchase reassurance"><span>4.2 stars on Amazon</span><span>No subscription required</span><span>Free shipping with Prime</span><span>30-day returns through Amazon</span></div>
        </div>
        <img src="/images/nubo-instant-tracker-1400.webp" srcset="/images/nubo-instant-tracker-900.webp 900w, /images/nubo-instant-tracker-1400.webp 1400w" sizes="(max-width: 900px) 92vw, 48vw" alt="Hand pressing the Nubo instant tracker beside a sleeping baby" width="1400" height="1400" loading="eager" decoding="async" />
      </div>
    </section>

    <SpeedComparison expanded />

    <section class="three-speeds-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Three ways to log</p><h2>Use the fastest input that fits the moment.</h2></div>
        <div class="speed-card-grid">
          <article><span>1 sec</span><h3>Device press</h3><p>Best for nighttime feeds, diaper changes, and any moment where unlocking your phone would pull attention away.</p></article>
          <article><span>4 sec</span><h3>Quick Log</h3><p>Best when your phone is already open and you want a fast tap-based entry.</p></article>
          <article><span>8 sec</span><h3>Voice logging</h3><p>Best for catch-up logging after a feed, pump, medicine dose, or caregiver handoff.</p></article>
        </div>
      </div>
    </section>

    <section class="moments-section">
      <div class="container">
        <div class="section-intro"><p class="overline">Real life moments</p><h2>Built for the moments apps make harder.</h2></div>
        <div class="moment-grid">
          <article><h3>Night feeds</h3><p>Tap the button without bright screens, app navigation, or a phone search in the dark.</p></article>
          <article><h3>Hands-full diaper changes</h3><p>Mark pee or poop while the change is happening, then add notes later if you need them.</p></article>
          <article><h3>Caregiver handoff</h3><p>Nanny or grandparent logs from the device, then their phone syncs when it is nearby.</p></article>
          <article><h3>Pediatrician prep</h3><p>Keep a more complete history for questions about intake, output, sleep, medicine, and growth.</p></article>
        </div>
      </div>
    </section>

    <section class="mechanics-section">
      <div class="container mechanics-grid">
        <div>
          <p class="overline">How the device works</p>
          <h2>A button simple enough for 3 a.m.</h2>
          <ol>
            <li><strong>Press:</strong> Log feeding, sleep, pee, or poop with a physical button.</li>
            <li><strong>Store:</strong> The device keeps the timestamp even before a phone connects.</li>
            <li><strong>Sync:</strong> Bluetooth sends logs to the app when a caregiver phone is nearby.</li>
            <li><strong>Review:</strong> The app shows history, charts, exports, reminders, and caregiver notes.</li>
          </ol>
        </div>
        <div class="spec-card">
          <h3>Included in the box</h3>
          <ul>
            <li>Nubo physical tracker</li>
            <li>Magnetic mount</li>
            <li>Lanyard</li>
            <li>Battery designed for months of everyday use</li>
            <li>Setup with the free Nubo app</li>
          </ul>
        </div>
      </div>
    </section>

    <PremiumFollowsDevice />
    <CaregiverEconomics />

    <section class="gift-section">
      <div class="container gift-grid">
        <div>
          <p class="overline">Baby shower and second baby</p>
          <h2>A practical gift that keeps working.</h2>
          <p>The device is a simple gift because it does not ask new parents to choose a subscription on day one. It also keeps working for a second baby, future caregiver routines, and the next phase of family life.</p>
          <div class="hero-actions-inline"><a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy on Amazon</a><a href="/gift/" class="btn-ghost">Gift guide</a></div>
        </div>
        <img src="/images/caregiver-hub.webp" alt="Nubo baby tracker shared across caregiver phones" width="970" height="600" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="second-baby-section">
      <div class="container second-baby-inner">
        <div>
          <p class="overline">Future babies</p>
          <h2>What about a second baby?</h2>
          <p>The device is not tied to one newborn stage. Put it back near the crib, pair it with the app, and use the same one-button habit when your household starts again.</p>
        </div>
        <div class="second-baby-grid">
          <article><h3>Hardware keeps working</h3><p>The physical tracker, mount, and lanyard can move with your nursery setup instead of becoming a one-child purchase.</p></article>
          <article><h3>The app supports profiles</h3><p>Nubo keeps child timelines separate, so a future baby can have their own record without losing older history.</p></article>
          <article><h3>Caregivers come back faster</h3><p>Partners and grandparents who already know the button do not need to learn a new logging system the next time.</p></article>
        </div>
      </div>
    </section>

    <section class="faq-band">
      <div class="container">
        <div class="section-intro"><p class="overline">Device FAQ</p><h2>Before you buy.</h2></div>
        <div class="faq-grid">
          <article><h3>Does the device require a Premium subscription?</h3><p>No. The device works with the free app and grants Premium to every phone that connects to it for 30 days.</p></article>
          <article><h3>Can caregivers use different phones?</h3><p>Yes. The device can grant Premium across separate App Store and Google Play accounts when caregiver phones connect to it.</p></article>
          <article><h3>What if a caregiver visits occasionally?</h3><p>Their Premium access lasts 30 days after sync. When they visit again and sync with the device, Premium refreshes.</p></article>
          <article><h3>Can I use the app without the device?</h3><p>Yes. The free Nubo app is useful on its own. The device adds the fastest logging method and caregiver Premium economics.</p></article>
          <article><h3>What can the button track?</h3><p>The device covers the highest-frequency newborn events: feeds, sleep, pee, and poop.</p></article>
          <article><h3>Can I return it?</h3><p>Nubo is sold through Amazon, so returns follow Amazon's standard return policy.</p></article>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .device-hero { padding: 8rem 0 5rem; background: var(--color-bg-warm); }
  .device-hero-grid, .mechanics-grid, .gift-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .device-hero-grid { align-items: start; }
  .device-hero h1 { font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1; letter-spacing: 0; max-width: 760px; }
  .hero-sub { font-size: 1.25rem; line-height: 1.7; color: var(--color-text-secondary); margin: 1.5rem 0 0; max-width: 640px; }
  .hero-actions-inline { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .device-hero img, .gift-grid img { width: 100%; height: auto; border-radius: var(--radius-xl); box-shadow: 0 24px 60px rgba(0, 0, 0, 0.1); }
  @media (min-width: 981px) { .device-hero-grid > img { margin-top: calc(0.8125rem * 1.6 + 0.75rem); } }
  .trust-strip { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
  .trust-strip span { background: #fff; border-radius: 999px; padding: 0.625rem 0.875rem; font-size: 0.8125rem; font-weight: 700; }
  .three-speeds-section, .moments-section, .mechanics-section, .gift-section, .second-baby-section, .faq-band { padding: 6rem 0; }
  .three-speeds-section, .mechanics-section, .second-baby-section, .faq-band { background: #fff; }
  .moments-section, .gift-section { background: var(--color-bg-soft); }
  .speed-card-grid, .moment-grid, .second-baby-grid, .faq-grid { display: grid; gap: 1.5rem; }
  .speed-card-grid { grid-template-columns: repeat(3, 1fr); }
  .moment-grid, .faq-grid { grid-template-columns: repeat(2, 1fr); }
  .second-baby-grid { grid-template-columns: repeat(3, 1fr); }
  .speed-card-grid article, .moment-grid article, .second-baby-grid article, .spec-card, .faq-grid article { background: #fff; border: 1px solid #e8e8e8; border-radius: var(--radius-xl); padding: 1.75rem; }
  .three-speeds-section .speed-card-grid article { background: var(--color-bg-soft); }
  .speed-card-grid span { display: inline-flex; margin-bottom: 1rem; color: var(--color-brand-dark); font-size: 2.5rem; font-weight: 700; line-height: 1; }
  .speed-card-grid h3, .moment-grid h3, .second-baby-grid h3, .spec-card h3, .faq-grid h3 { font-size: 1.125rem; line-height: 1.25; margin-bottom: 0.75rem; }
  .speed-card-grid p, .moment-grid p, .mechanics-grid li, .gift-grid p, .second-baby-inner p, .faq-grid p { color: var(--color-text-secondary); line-height: 1.7; }
  .mechanics-grid h2, .gift-grid h2, .second-baby-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .second-baby-inner { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 4rem; align-items: start; }
  .mechanics-grid ol, .spec-card ul { display: grid; gap: 0.875rem; padding-left: 1.25rem; }
  .gift-grid .btn-primary { margin-top: 1.5rem; }
  @media (max-width: 980px) { .device-hero-grid, .mechanics-grid, .gift-grid, .second-baby-inner { grid-template-columns: 1fr; gap: 2.5rem; } .device-hero { padding-top: 6rem; } }
  @media (max-width: 760px) { .speed-card-grid, .moment-grid, .second-baby-grid, .faq-grid { grid-template-columns: 1fr; } .three-speeds-section, .moments-section, .mechanics-section, .gift-section, .second-baby-section, .faq-band { padding: 4rem 0; } }
</style>