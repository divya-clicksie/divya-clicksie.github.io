---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Talli Alternative: Nubo vs Talli Baby Tracker Device';
const description = 'Looking for a Talli alternative? Compare Nubo and Talli baby tracker devices by hardware availability, sync style, app model, caregiver fit, and phone-light newborn logging.';
const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';
const talliHomeURL = 'https://talli.me/';
const talliProductURL = 'https://talli.me/products/talli-baby-tracker-event-logger';
const talliAmazonURL = 'https://www.amazon.com/Talli-Daily-One-Touch-Baby-Tracker/dp/B0DJN6B1HB';

const faqItems = [
  {
    q: 'What is the best Talli alternative for physical baby tracking?',
    a: 'Nubo is a practical Talli alternative for families who want a physical baby tracker device, phone-light logging, iPhone and Android apps, caregiver sync, and direct Amazon purchase.'
  },
  {
    q: 'Is Talli still selling its baby tracker device?',
    a: 'Talli says hardware manufacturing is paused, current inventory is sold out, and the Talli app remains available. Product availability can change, so check the current Talli product page and Amazon listing before buying.'
  },
  {
    q: 'Does Nubo work like Talli?',
    a: 'Both products support one-press baby logging, but they use different approaches. Nubo uses Bluetooth sync, device-side event storage, a pocketable form factor, and a free app-first path. Talli uses Wi-Fi syncing and offers broader button customization.'
  },
  {
    q: 'Does Nubo require Wi-Fi?',
    a: 'No. The Nubo device syncs over Bluetooth when a paired caregiver phone is nearby. It does not require Wi-Fi.'
  },
  {
    q: 'Can grandparents, nannies, or sitters use Nubo?',
    a: 'Yes. Nubo is designed for shared care. Helpers can tap the physical device for common baby events, and caregiver phones can sync to the same baby timeline.'
  }
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: 'https://www.nubotracker.com/compare/talli/',
  about: [
    { '@type': 'Product', name: 'Nubo Baby Tracker Device' },
    { '@type': 'Product', name: 'Talli Baby One-Touch Baby Tracker' }
  ],
  mainEntity: {
    '@type': 'FAQPage',
    mainEntity: faqItems.map((faq) => ({
      '@type': 'Question',
      name: faq.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.a
      }
    }))
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="page-hero talli-hero">
      <div class="container">
        <p class="overline">Talli alternative</p>
        <h1>Looking for a Talli alternative? Compare Nubo and Talli.</h1>
        <p class="page-hero-sub">If you were considering Talli for one-press baby tracking, you may be looking for another physical baby tracker now that Talli says hardware manufacturing is paused and current inventory is sold out. Nubo offers a physical baby tracker device, a free iPhone and Android app, Bluetooth sync, caregiver sharing, and direct Amazon purchase.</p>
        <div class="hero-actions-inline">
          <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy Nubo on Amazon</a>
          <a href="/device/" class="btn-ghost">See Nubo device</a>
        </div>
        <p class="source-note">Device-level comparison based on public Talli website and Amazon information reviewed June 30, 2026.</p>
      </div>
    </section>

    <section class="availability-section">
      <div class="container availability-inner">
        <div>
          <p class="overline">Hardware availability</p>
          <h2>Is Talli still selling the baby tracker device?</h2>
          <p>Talli says hardware manufacturing is paused, current inventory is sold out, and the app remains available. The company also notes that limited two-packs may still be available through Amazon while supplies last.</p>
        </div>
        <div class="availability-card">
          <h3>What that means if you wanted buttons</h3>
          <p>If your goal is a physical baby tracker, compare currently available hardware before building your routine around an app-only fallback. Nubo is available through Amazon and keeps app, device, and caregiver logs in one baby timeline.</p>
          <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy Nubo on Amazon</a>
        </div>
      </div>
    </section>

    <section class="table-section">
      <div class="container">
        <div class="section-intro">
          <p class="overline">Side-by-side</p>
          <h2>The practical differences for families comparing Talli alternatives.</h2>
        </div>

        <div class="compare-table-wrap">
          <table class="compare-table">
            <caption>Nubo and Talli baby tracker device comparison</caption>
            <thead>
              <tr>
                <th scope="col">Question</th>
                <th scope="col">Nubo</th>
                <th scope="col">Talli</th>
              </tr>
            </thead>
            <tbody>
              <tr><th scope="row">Hardware availability</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Available through Amazon</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Talli says current inventory is sold out</span></span></td></tr>
              <tr><th scope="row">Direct purchase path</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Buy Nubo on Amazon</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-partial" aria-label="Partial">~</span><span>Limited Amazon two-packs may remain</span></span></td></tr>
              <tr><th scope="row">Device price</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>$89.99 listed</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>$109.99 listed</span></span></td></tr>
              <tr><th scope="row">Premium in-app features</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free for every syncing phone</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>14-day trial, then $39.99/year</span></span></td></tr>
              <tr><th scope="row">iOS/Device compatibility</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>iPhone app</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>iPhone app</span></span></td></tr>
              <tr><th scope="row">Android/Device compatibility</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Android app</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Currently iOS-only</span></span></td></tr>
              <tr><th scope="row">Connectivity</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Bluetooth 5.0</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-partial" aria-label="Partial">~</span><span>Wi-Fi (Incompatible with 5GHz routers)</span></span></td></tr>
              <tr><th scope="row">Offline logging</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Stores on device</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>No device storage</span></span></td></tr>
              <tr><th scope="row">On-the-go logging</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Hospital, park, daycare, airplane</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Known Wi-Fi to transmit</span></span></td></tr>
              <tr><th scope="row">Exact milk amount from device</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Multi-click amount</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>App edit for non-default</span></span></td></tr>
              <tr><th scope="row">Form factor</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Handheld or pocketable remote</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Larger tabletop or wall device</span></span></td></tr>
              <tr><th scope="row">Portable mount and carry options</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Magnet, sticker, lanyard</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Fixed spot or wall mount</span></span></td></tr>
              <tr><th scope="row">Water-resistance</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Yes</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not publicly positioned</span></span></td></tr>
              <tr><th scope="row">Child lock for siblings</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Locks accidental presses</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>No child lock listed</span></span></td></tr>
              <tr><th scope="row">Multi-month charge-free operation</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>CR2032, spare included</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Four AA batteries</span></span></td></tr>
              <tr><th scope="row">Broad all-button customization</th><td><span class="compare-cell"><span class="compare-mark compare-partial" aria-label="Partial">~</span><span>Focused buttons, one custom</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>8 custom buttons</span></span></td></tr>
            </tbody>
          </table>
        </div>

        <div class="compare-table-wrap">
          <table class="compare-table">
            <caption>Nubo and Talli baby tracker app comparison</caption>
            <thead>
              <tr>
                <th scope="col">Question</th>
                <th scope="col">Nubo App</th>
                <th scope="col">Talli App</th>
              </tr>
            </thead>
            <tbody>
              <tr><th scope="row">Phone Compatibility</th>
                <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>iOS and Android</span></span></td>
                <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>iOS and Android</span></span></td>
              </tr>

              <tr><th scope="row">Premium in-app features</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free for every syncing phone</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>14-day trial, then $39.99/year</span></span></td></tr>
              
              <tr><th scope="row">User account</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Optional</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Required</span></span></td></tr>
              
              <tr><th scope="row">Data storage</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>App storage, private backup</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Cloud account model</span></span></td></tr>

              <tr><th scope="row">Offline mode</th><td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Fully supported</span></span></td><td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Requires internet access</span></span></td></tr>

              <tr><th scope="row">One-tap logging</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free, unlimited</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Premium</span></span></td>
              </tr>

              <tr><th scope="row">Voice logging</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free, on-device, unlimited</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">Voice Notes</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free, unlimited</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">Growth Tracking</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free WHO charts</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">Growth Tracking (Pre-term)</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free Fenton Charts</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">CDC Milestones</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Yes</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">Multiple Children</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Supported</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Supported</span></span></td>
              </tr>
              <tr><th scope="row">Multiple Caregivers</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Supported</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Supported</span></span></td>
              </tr>
              <tr><th scope="row">Reminders and Auto-Reminders</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Supported</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Supported</span></span></td>
              </tr>
              <tr><th scope="row">Pumping, Collection Tracking</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Premium, private</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Free, shared, no collection</span></span></td>
              </tr>
              <tr><th scope="row">Allergen Introduction</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Premium</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">Care Vault</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Premium</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">Light/Dark Mode</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Free</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Free</span></span></td>
              </tr>
              <tr><th scope="row">Melatonin mode</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Premium</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
              <tr><th scope="row">Sleep Sounds</th>
              <td><span class="compare-cell"><span class="compare-mark compare-yes" aria-label="Yes">✓</span><span>Premium</span></span></td>
              <td><span class="compare-cell"><span class="compare-mark compare-no" aria-label="No">X</span><span>Not available</span></span></td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <div class="section-intro">
          <p class="overline">Talli alternative FAQ</p>
          <h2>Quick answers before you choose a physical baby tracker.</h2>
        </div>
        <div class="faq-grid">
          {faqItems.map((faq) => (
            <article>
              <h3>{faq.q}</h3>
              <p>{faq.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>


    <section class="phone-light-section">
      <div class="container phone-light-inner">
        <div>
          <p class="overline">For Nubo families</p>
          <h2>If your goal is less phone around the baby, start here.</h2>
          <p>Nubo is for the parent who wants the log without inviting the phone into every quiet moment. Tap the device for common newborn events, use the free app when the phone is already with you, and let every caregiver work from one timeline.</p>
        </div>
        <div class="phone-light-actions">
          <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy Nubo on Amazon</a>
          <a href={appStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Download on App Store</a>
          <a href={playStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Get it on Google Play</a>
        </div>
      </div>
    </section>

    <section class="source-section">
      <div class="container source-inner">
        <p class="overline">Sources</p>
        <p>Talli details were taken from the public <a href={talliHomeURL} target="_blank" rel="noopener noreferrer">Talli homepage</a>, <a href={talliProductURL} target="_blank" rel="noopener noreferrer">Talli Baby product page</a>, and <a href={talliAmazonURL} target="_blank" rel="noopener noreferrer">Talli Amazon listing</a>. Product pages can change, so verify current availability, pricing, subscription terms, compatibility, and feature details before buying.</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .talli-hero .hero-actions-inline { justify-content: center; }
  .hero-actions-inline { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .source-note { margin-top: 1rem; color: var(--color-text-secondary); font-size: 0.875rem; }
  .table-section, .availability-section, .faq-section, .phone-light-section, .source-section { padding: 6rem 0; }
  .source-section { background: #fff; }
  .table-section, .phone-light-section { background: var(--color-bg-soft); }
  .availability-section, .faq-section { background: #fff; }
  .availability-inner { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 2rem; align-items: stretch; }
  .availability-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .availability-inner p { color: var(--color-text-secondary); line-height: 1.7; }
  .availability-card { border: 1px solid #e8e8e8; border-radius: var(--radius-xl); padding: 2rem; background: var(--color-bg-soft); display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; }
  .availability-card h3 { font-size: 1.25rem; margin: 0; }
  .availability-card p { margin: 0; }
  .phone-light-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: stretch; }
  .phone-light-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .phone-light-inner p, .source-inner p { color: var(--color-text-secondary); line-height: 1.7; }
  .compare-table-wrap { overflow-x: auto; border: 1px solid #e8e8e8; border-radius: var(--radius-xl); background: #fff; }
  .compare-table-wrap + .compare-table-wrap { margin-top: 3rem; }
  .compare-table { width: 100%; min-width: 980px; table-layout: fixed; border-collapse: collapse; }
  .compare-table caption { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0, 0, 0, 0); }
  .compare-table th, .compare-table td { padding: 0.95rem 1rem; border-bottom: 1px solid #eeeeee; text-align: left; line-height: 1.35; vertical-align: middle; }
  .compare-table th:nth-child(1), .compare-table td:nth-child(1) { width: 32%; }
  .compare-table th:nth-child(2), .compare-table td:nth-child(2) { width: 34%; }
  .compare-table th:nth-child(3), .compare-table td:nth-child(3) { width: 34%; }
  .compare-table thead th { background: #fff; color: var(--color-text); font-size: 0.875rem; }
  .compare-table thead th:nth-child(2) { background: rgba(61, 179, 173, 0.08); color: var(--color-brand-dark); }
  .compare-table tbody th { color: var(--color-text); font-weight: 800; }
  .compare-table tbody td:nth-child(2) { background: rgba(61, 179, 173, 0.06); }
  .compare-table td { color: var(--color-text-secondary); }
  .compare-table tbody tr:last-child th, .compare-table tbody tr:last-child td { border-bottom: 0; }
  .compare-cell { display: flex; align-items: center; gap: 0.65rem; font-weight: 700; color: var(--color-text); }
  .compare-mark { display: inline-grid; place-items: center; flex: 0 0 auto; width: 1.65rem; height: 1.65rem; border-radius: 999px; font-size: 0.95rem; font-weight: 900; line-height: 1; }
  .compare-yes { background: var(--color-brand-light); color: var(--color-brand-dark); }
  .compare-no { background: #f3f3f3; color: #8a8a8a; }
  .compare-partial { background: #fff5d8; color: #8a6500; }
  .phone-light-inner { align-items: center; }
  .phone-light-actions { display: flex; flex-direction: column; gap: 1rem; justify-self: end; width: min(100%, 420px); }
  .phone-light-actions .btn-primary, .phone-light-actions .btn-ghost { width: 100%; justify-content: center; }
  .faq-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; margin-top: 2rem; }
  .faq-grid article { border: 1px solid #e8e8e8; border-radius: var(--radius-xl); padding: 1.5rem; background: #fff; }
  .faq-grid h3 { font-size: 1.05rem; line-height: 1.25; margin: 0 0 0.75rem; }
  .faq-grid p { color: var(--color-text-secondary); line-height: 1.65; margin: 0; }
  .source-inner { max-width: 760px; }
  .source-inner a { color: var(--color-brand-dark); font-weight: 700; }
  @media (max-width: 900px) { .availability-inner, .phone-light-inner, .faq-grid { grid-template-columns: 1fr; } .phone-light-actions { justify-self: start; } }
  @media (max-width: 640px) { .table-section, .availability-section, .faq-section, .phone-light-section, .source-section { padding: 4rem 0; } .phone-light-actions .btn-primary, .phone-light-actions .btn-ghost { width: 100%; } }
</style>
