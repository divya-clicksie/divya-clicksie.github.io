---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Nubo Baby Tracker | 3 Ways to Log Feedings, Sleep & Diapers';
const description = 'Nubo gives you three ways to track your baby: tap the device, ask Alexa, or use the app. Every log lands in one timeline. Every caregiver stays in sync.';

const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';
const alexaURL = 'https://www.amazon.com/Clicksie-LLC-Nubo-Baby-Tracker/dp/B0FJ2N8XKB';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Nubo Baby Activity Tracker",
  "description": "Baby tracking ecosystem with a physical device, Alexa skill, and companion app for logging feedings, sleep, and diapers.",
  "image": "https://www.nubotracker.com/images/hero.webp",
  "brand": {
    "@type": "Brand",
    "name": "nubo",
    "sameAs": [
      "https://www.instagram.com/nubo_baby_tracker",
      "https://www.youtube.com/@NuboBabyTracker"
    ]
  },
  "offers": {
    "@type": "Offer",
    "url": amazonURL,
    "priceCurrency": "USD",
    "price": "89.99",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.2",
    "reviewCount": "32"
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>

    <!-- ════════════════════════════════════════════
         HERO
    ════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-glow"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-content reveal">
          <p class="overline">The fastest way to track your baby.</p>
          <h1>
            Nobody remembers at 3&nbsp;a.m.
            <span class="hero-accent">Nubo does.</span>
          </h1>
          <p class="hero-sub">
            Tap the device. Ask Alexa. Or log in the app.
            Every feeding, nap, and diaper lands in one place, so every caregiver stays in sync.
          </p>
          <div class="hero-actions">
            <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">
              Buy on Amazon
            </a>
            <a href="#three-ways" class="btn-ghost">See how it works</a>
          </div>
          <div class="hero-trust">
            <span>Device, Alexa, or App</span>
            <span class="trust-sep">&middot;</span>
            <span>Free app for every caregiver</span>
            <span class="trust-sep">&middot;</span>
            <span>Private by design</span>
          </div>
        </div>
        <div class="hero-image reveal reveal-delay-2">
          <img
            src="/images/hero.webp"
            alt="A mother tenderly holding her newborn, with Nubo baby tracker in the foreground"
            width="760"
            height="862"
            loading="eager"
          />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PAIN POINT
    ════════════════════════════════════════════ -->
    <section class="pain-point">
      <div class="container">
        <div class="pain-inner reveal">
          <p class="overline">Sound familiar?</p>
          <p class="pain-text">
            You're breastfeeding in the dark. Your phone is across the room.
            You're in the kitchen warming a bottle with both hands full.
            You just changed a diaper and the baby's already crying again.
            Logging it shouldn't be one more thing to forget.
          </p>
          <p class="pain-relief">That's why Nubo gives you three ways to log. Pick the one that fits the moment.</p>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         THREE WAYS TO LOG
    ════════════════════════════════════════════ -->
    <section class="three-ways" id="three-ways">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">The Nubo Ecosystem</p>
          <h2>Three ways to log.<br/>One timeline.</h2>
          <p class="section-sub">Every feeding, nap, and diaper change flows into the Nubo app. Pick the way that fits the moment.</p>
        </div>

        <div class="ways-grid">
          <div class="way-card reveal">
            <div class="way-card-image">
              <img src="/images/nubo-device-hand.png" alt="Hand pressing a button on the Nubo baby tracker device" width="640" height="400" loading="lazy"/>
            </div>
            <div class="way-card-body">
              <h3>Tap the device</h3>
              <p>One-handed. Eyes closed. In the dark. Press a button on Nubo and the activity is logged. Takes about one second.</p>
              <span class="way-best">Best for: midnight feeds, holding baby, when your phone is out of reach</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-1">
            <div class="way-card-image">
              <img src="/images/nubo-alexa-echo-show.png" alt="Nubo baby tracker dashboard displayed on an Amazon Echo Show" width="640" height="400" loading="lazy"/>
            </div>
            <div class="way-card-body">
              <h3>Ask Alexa</h3>
              <p>&ldquo;Alexa, tell Newborn tracker I breast fed baby for half an hour.&rdquo; Natural language logging when your hands are full.</p>
              <span class="way-best">Best for: bottle prep, hands full, multitasking</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-2">
            <div class="way-card-image">
              <img src="/images/nubo-app-screens.png" alt="Nubo baby tracker app showing dashboard, activity log, and feeding charts" width="640" height="400" loading="lazy"/>
            </div>
            <div class="way-card-body">
              <h3>Use the app</h3>
              <p>Full control when you have a free moment. View trends, add details, export data for the pediatrician, and share with every caregiver.</p>
              <span class="way-best">Best for: reviewing patterns, adding notes, doctor visits</span>
              <div class="way-store-links">
                <a href={appStoreURL} target="_blank" rel="noopener noreferrer">
                  <img src="/images/appstore-badge.png" alt="Download on the App Store" width="120" height="42" />
                </a>
                <a href={playStoreURL} target="_blank" rel="noopener noreferrer">
                  <img src="/images/playstore-badge.png" alt="Get it on Google Play" width="120" height="42" />
                </a>
              </div>
            </div>
          </div>
        </div>

        <p class="ways-convergence reveal">All three feed into the same timeline. Nothing gets lost. Every caregiver sees the same data.</p>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         MEET NUBO (DEVICE)
    ════════════════════════════════════════════ -->
    <section class="meet-nubo" id="features">
      <div class="container meet-inner">
        <div class="meet-image reveal">
          <img
            src="/images/nubo-oneclick.webp"
            alt="Close-up of a finger pressing the sleep button on Nubo for one touch logging"
            width="740"
            height="554"
          />
        </div>
        <div class="meet-text reveal reveal-delay-1">
          <p class="overline">The Device</p>
          <h2>
            Like a light switch<br/>
            for baby tracking.
          </h2>
          <p class="meet-description meet-description-lead">
            One tap. A gentle light. Done.
          </p>
          <p class="meet-description">
            Nubo is a physical tracker built for the moments your phone can't reach.
            Press a button to log feeds, sleep, pee, and poop. It stores everything
            and syncs to the app when your phone is nearby.
          </p>
          <p class="meet-description">
            Use it one-handed, half-asleep, in the dark. Get back to your baby.
          </p>
        </div>
      </div>

      <div class="container meet-videos reveal">
        <div class="video-grid">
          <a href="https://www.youtube.com/watch?v=NH5-ECtIpzw" target="_blank" rel="noopener noreferrer" class="video-thumb">
            <img src="https://img.youtube.com/vi/NH5-ECtIpzw/maxresdefault.jpg" alt="Unboxing the Nubo baby tracker" width="480" height="270" loading="lazy" />
            <span class="video-play" aria-hidden="true"></span>
            <span class="video-label">Unbox</span>
          </a>
          <a href="https://www.youtube.com/watch?v=2XT00mDc2-U" target="_blank" rel="noopener noreferrer" class="video-thumb">
            <img src="https://img.youtube.com/vi/2XT00mDc2-U/maxresdefault.jpg" alt="Setting up the Nubo baby tracker" width="480" height="270" loading="lazy" />
            <span class="video-play" aria-hidden="true"></span>
            <span class="video-label">Setup</span>
          </a>
          <a href="https://www.youtube.com/watch?v=RyiNBesv804" target="_blank" rel="noopener noreferrer" class="video-thumb">
            <img src="https://img.youtube.com/vi/RyiNBesv804/maxresdefault.jpg" alt="Using Nubo to track baby activities and review in the app" width="480" height="270" loading="lazy" />
            <span class="video-play" aria-hidden="true"></span>
            <span class="video-label">Track &amp; Review</span>
          </a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         BUILT FOR REAL LIFE (feature strip)
    ════════════════════════════════════════════ -->
    <section class="feature-strip">
      <div class="feature-strip-track">
        <div class="fs-card reveal">
          <div class="fs-icon">🏥</div>
          <h3>Ready for the hospital</h3>
          <p>Set up Nubo before baby arrives, lock it, and pack it in your hospital bag. When it's time, just unlock and start tracking.</p>
        </div>
        <div class="fs-card reveal reveal-delay-1">
          <div class="fs-icon">📡</div>
          <h3>Works wherever baby goes</h3>
          <p>Home, park, or daycare. Nubo sends logs to every caregiver's phone in real time. Always in sync.</p>
        </div>
        <div class="fs-card reveal reveal-delay-2">
          <div class="fs-icon">💧</div>
          <h3>Built for real life</h3>
          <p>Spills happen. Nubo can handle them. Just wipe it clean and keep going. No stress, no mess.</p>
        </div>
        <div class="fs-card reveal">
          <div class="fs-icon">🔋</div>
          <h3>Battery that lasts</h3>
          <p>No charging, no downtime. Runs for months on a coin cell and comes with a spare. Always ready.</p>
        </div>
        <div class="fs-card reveal reveal-delay-1">
          <div class="fs-icon">🧲</div>
          <h3>Always within reach</h3>
          <p>Stick Nubo on your fridge, crib, or wall. Magnetic mount and sticker included. Grab it fast. Log it fast.</p>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         ALEXA
    ════════════════════════════════════════════ -->
    <section class="alexa-section">
      <div class="container alexa-inner">
        <div class="alexa-top">
          <div class="alexa-text reveal">
            <p class="overline">Works with Alexa</p>
            <h2>Hands full?<br/>Just say the word.</h2>
            <p class="alexa-description">
              Nubo for Alexa makes logging your newborn's routine effortless, hands-free and secure.
              Simply ask Alexa to record sleep, feeding or diaper changes. Use natural language or quick commands.
            </p>
            <p class="alexa-invoke-hint">Say: &ldquo;Alexa, open Newborn tracker&rdquo; or &ldquo;Alexa, tell Newborn tracker to ...&rdquo;</p>
          </div>
          <div class="alexa-visual reveal reveal-delay-1">
            <a href={alexaURL} target="_blank" rel="noopener noreferrer" class="alexa-badge-link">
              <img src="/images/nubo-alexa-echo-show.png" alt="Nubo baby tracker dashboard on Amazon Echo Show displaying sleep, feeding, and diaper status at a glance" class="alexa-show-img" width="640" height="400" loading="lazy"/>
            </a>
          </div>
        </div>
        <div class="alexa-examples reveal">
          <div class="alexa-example-group">
            <p class="alexa-examples-label">Sleep</p>
            <div class="alexa-pills">
              <span class="alexa-pill">&ldquo;My baby started napping at 2 PM.&rdquo;</span>
              <span class="alexa-pill">&ldquo;Baby woke up.&rdquo;</span>
              <span class="alexa-pill">&ldquo;Baby slept from 3 to 6 in the evening.&rdquo;</span>
            </div>
          </div>
          <div class="alexa-example-group">
            <p class="alexa-examples-label">Nursing</p>
            <div class="alexa-pills">
              <span class="alexa-pill">&ldquo;Log a nursing session, left side, 15 minutes.&rdquo;</span>
              <span class="alexa-pill">&ldquo;I breast fed baby for half an hour.&rdquo;</span>
            </div>
          </div>
          <div class="alexa-example-group">
            <p class="alexa-examples-label">Bottle</p>
            <div class="alexa-pills">
              <span class="alexa-pill">&ldquo;Record 4 ounces of milk. 10 minutes ago.&rdquo;</span>
              <span class="alexa-pill">&ldquo;Formula. 1 ounce. Just now.&rdquo;</span>
              <span class="alexa-pill">&ldquo;Log 2 ounces of formula and 1 ounce of milk.&rdquo;</span>
            </div>
          </div>
          <div class="alexa-example-group">
            <p class="alexa-examples-label">Diapers</p>
            <div class="alexa-pills">
              <span class="alexa-pill">&ldquo;Diaper change. Wet.&rdquo;</span>
              <span class="alexa-pill">&ldquo;I changed baby's diaper. It was wet and dirty.&rdquo;</span>
            </div>
          </div>
        </div>
      </div>
    </section>




    <!-- ════════════════════════════════════════════
         CAREGIVERS
    ════════════════════════════════════════════ -->
    <section class="caregivers" id="caregivers">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Nubo for Everyone</p>
          <h2>Every caregiver.<br/>One page. Always.</h2>
          <p class="section-sub">Mom, dad, grandparents, nanny. Everyone sees the same data. No more &ldquo;did you feed the baby?&rdquo; texts.</p>
        </div>

        <div class="caregivers-grid">
          <div class="caregiver-card reveal">
            <div class="caregiver-img">
              <img src="/images/audience-parents.png" alt="Parents viewing their Nubo app to understand their newborn's routine" width="600" height="432" />
            </div>
            <div class="caregiver-text">
              <h3>For parents</h3>
              <p>Understand your newborn's routine. See patterns in feeding, sleep, and diapers to plan your day with confidence.</p>
            </div>
          </div>

          <div class="caregiver-card reveal reveal-delay-1">
            <div class="caregiver-img">
              <img src="/images/audience-grandparents.png" alt="Grandparents holding their grandchild with the Nubo collaboration screen on phone" width="600" height="432" />
            </div>
            <div class="caregiver-text">
              <h3>For grandparents &amp; nannies</h3>
              <p>No complicated tracking flow to learn. Just tap when something happens, and parents can review the timeline in the app.</p>
            </div>
          </div>

          <div class="caregiver-card reveal reveal-delay-2">
            <div class="caregiver-img">
              <img src="/images/audience-doctors.png" alt="Pediatrician reviewing baby's feeding and sleep data on phone during a checkup" width="600" height="432" />
            </div>
            <div class="caregiver-text">
              <h3>For pediatricians</h3>
              <p>Parents arrive with accurate, timestamped data. Feeding volumes, sleep duration, output. No more guesswork.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         REVIEWS
    ════════════════════════════════════════════ -->
    <section class="reviews" id="reviews">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Real Reviews</p>
          <h2>Parents who've<br/>been there.</h2>
        </div>

        <div class="reviews-aggregate reveal">
          <span class="agg-stars" aria-label="4.2 out of 5 stars">★★★★☆</span>
          <span class="agg-text">4.2 stars on Amazon</span>
        </div>

        <div class="reviews-grid">
          <blockquote class="review reveal">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;I tried three baby-tracker apps before this. All felt like spreadsheets with pastel icons. <strong>Nubo is the first one I can use half-asleep.</strong>&rdquo;</p>
            <footer><strong>Kiran K.</strong> &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-1">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;So much easier to tag team with our baby. If one of us has been out, the other can just <strong>glance at the app and see what's been going on.</strong>&rdquo;</p>
            <footer><strong>Devi</strong> &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-2">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;Our preemie needed exact intake tracking for the NICU follow-up. <strong>We exported the data and the pediatrician was impressed</strong> by how complete it was.&rdquo;</p>
            <footer><strong>Priya M.</strong> &middot; Austin, TX &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-3">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;My husband, my mom, and I all use Nubo. <strong>Nobody has to ask &lsquo;when did the baby eat last?&rsquo; anymore.</strong> That alone is worth it.&rdquo;</p>
            <footer><strong>Jessica R.</strong> &middot; Portland, OR &middot; Verified Purchase</footer>
          </blockquote>
        </div>

        <div class="reviews-link reveal">
          <a href="https://www.amazon.com/product-reviews/B0CJLNBG4P" target="_blank" rel="noopener noreferrer">
            Read all reviews on Amazon &rarr;
          </a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PRIVACY
    ════════════════════════════════════════════ -->
    <section class="privacy" id="privacy">
      <div class="container privacy-inner">
        <div class="privacy-text reveal">
          <p class="overline">Privacy by Design</p>
          <h2>Your baby's data<br/>stays yours.</h2>
          <ul class="privacy-list">
            <li>No account required to use device or app</li>
            <li>Data stays on your phone, not our servers</li>
            <li>End-to-end encrypted sharing</li>
            <li>Backup to your own iCloud or Google Drive</li>
            <li>We never sell or share your information</li>
          </ul>
          <a href="/privacy-policy/" class="text-link">Read our privacy policy &rarr;</a>
        </div>
        <div class="privacy-visual reveal reveal-delay-1">
          <img src="/images/privacy-shield.png" alt="Nubo app interface showing privacy-first data widgets and encrypted sharing" width="600" height="405" />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         GIFT
    ════════════════════════════════════════════ -->
    <section class="gift" id="gift">
      <div class="container gift-inner">
        <div class="gift-image reveal">
          <img
            src="/images/nubo-gift.webp"
            alt="Nubo beautifully packaged as a gift in a premium white box with the device inside"
            width="600"
            height="480"
          />
        </div>
        <div class="gift-text reveal reveal-delay-1">
          <p class="overline">Baby Shower Favorite</p>
          <h2>The gift every new parent actually uses.</h2>
          <p class="gift-desc">
            Skip the onesies. Give the gift of time, sanity, and confidence.
            Nubo comes beautifully packaged and ready to unwrap. No wrapping needed.
          </p>
          <a href={amazonURL} class="btn-primary gift-cta" target="_blank" rel="noopener noreferrer">
            Gift it on Amazon
          </a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         COMPARE
    ════════════════════════════════════════════ -->
    <!-- COMPARE section hidden — promoting blog post instead
    <section class="compare">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Why Nubo?</p>
          <h2>Why parents choose Nubo over<br/>apps and paper notes.</h2>
        </div>
        <div class="compare-table-wrap reveal">
          <table class="compare-table">
            <thead>
              <tr>
                <th></th>
                <th class="compare-highlight">Nubo</th>
                <th>Phone Apps</th>
                <th>Pen &amp; Paper</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Log an activity</td>
                <td class="compare-highlight">1 second</td>
                <td>30+ seconds</td>
