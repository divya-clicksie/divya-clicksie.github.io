---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpeedComparison from '../components/SpeedComparison.astro';
import AttentionLine from '../components/AttentionLine.astro';

const title = 'Nubo Baby Tracker | One-Tap Baby Tracker for Night Feeds';
const description = 'The one-tap baby tracker for night feeds, hands-full moments, and multi-caregiver households. Use the device, free app, voice catch-up, and Alexa in one shared baby timeline.';

const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';
const alexaURL = 'https://www.amazon.com/Clicksie-LLC-Nubo-Baby-Tracker/dp/B0FJ2N8XKB';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": "Nubo Baby Activity Tracker",
      "alternateName": "One-tap baby tracker",
      "description": "The one-tap baby tracker for night feeds, hands-full moments, and multi-caregiver households. Nubo combines a physical device, in-app one-tap and voice logging, an Alexa skill, and a companion app for logging feedings, sleep, and diapers.",
      "image": "https://www.nubotracker.com/images/nubo-instant-tracker.webp",
      "url": "https://www.nubotracker.com/",
      "category": "Baby activity tracker",
      "brand": {
        "@type": "Brand",
        "name": "Nubo",
        "sameAs": [
          "https://www.instagram.com/nubo_baby_tracker",
          "https://www.youtube.com/@NuboBabyTracker"
        ]
      },
      "offers": {
        "@type": "Offer",
        "url": amazonURL,
        "priceCurrency": "USD",
        "price": "89.99",
        "availability": "https://schema.org/InStock"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.2",
        "reviewCount": "32"
      },
      "review": [
        {
          "@type": "Review",
          "reviewBody": "I tried three baby-tracker apps before this. All felt like spreadsheets with pastel icons. Nubo is the first one I can use half-asleep.",
          "author": { "@type": "Person", "name": "Kiran K." },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "reviewBody": "So much easier to tag team with our baby. If one of us has been out, the other can just glance at the app and see what's been going on.",
          "author": { "@type": "Person", "name": "Devi" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "reviewBody": "Our preemie needed exact intake tracking for the NICU follow-up. We exported the data and the pediatrician was impressed by how complete it was.",
          "author": { "@type": "Person", "name": "Priya M." },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "reviewBody": "My husband, my mom, and I all use Nubo. Nobody has to ask when did the baby eat last anymore. That alone is worth it.",
          "author": { "@type": "Person", "name": "Jessica R." },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        }
      ]
    },
    {
      "@type": "MobileApplication",
      "name": "Nubo Baby Tracker",
      "operatingSystem": "iOS, Android",
      "applicationCategory": "HealthApplication",
      "description": "Free baby tracker app with one-tap quick logging and on-device voice logging. Track feeds, sleep, diapers, growth (WHO and Fenton), vaccines, allergens, and milestones. Unlimited caregivers, unlimited cloud backup, full offline mode.",
      "image": "https://www.nubotracker.com/images/nubo-instant-tracker.webp",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "installUrl": appStoreURL,
      "downloadUrl": [appStoreURL, playStoreURL]
    }
  ]
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>

    <!-- ════════════════════════════════════════════
         HERO
    ════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-glow"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="overline">One-tap baby tracker</p>
          <h1>
            Nobody remembers at 3&nbsp;a.m.
            <span class="hero-accent">Nubo does.</span>
          </h1>
          <p class="hero-sub">
            Tap the device, even half-asleep. Or recap the night by voice in the morning. Every feed, nap, and diaper lands in one timeline.
          </p>
          <div class="hero-actions">
            <a href="/pricing/" class="btn-primary">
              Choose your setup
            </a>
            <a href={amazonURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">
              Buy the device
            </a>
          </div>
          <div class="hero-trust">
            <span class="trust-chip">Free</span>
            <span class="trust-chip">Unlimited</span>
            <span class="trust-chip">On-device &amp; private</span>
            <span class="trust-chip">No predictions. No pressure.</span>
          </div>
        </div>
        <div class="hero-image">
          <img
            src="/images/nubo-instant-tracker-900.webp"
            srcset="/images/nubo-instant-tracker-640.webp 640w, /images/nubo-instant-tracker-900.webp 900w, /images/nubo-instant-tracker-1400.webp 1400w"
            sizes="(max-width: 768px) 72vw, (max-width: 900px) 88vw, 48vw"
            alt="Hand pressing the Nubo instant tracker beside a sleeping baby"
            width="1400"
            height="1400"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PAIN POINT
    ════════════════════════════════════════════ -->
    <section class="pain-point">
      <div class="container">
        <div class="pain-inner reveal">
          <p class="overline">Sound familiar?</p>
          <p class="pain-text">
            You're breastfeeding in the dark. Your phone is across the room.
            You're in the kitchen warming a bottle with both hands full.
            You just changed a diaper and the baby's already crying again.
            Logging it shouldn't be one more thing to forget.
          </p>
          <p class="pain-relief">Tap as it happens. Talk to catch up. Whatever fits the moment. Everything stays in sync.</p>
        </div>
      </div>
    </section>


    <SpeedComparison compact ctaHref="/compare/" ctaLabel="See the full comparison" />


    <!-- ════════════════════════════════════════════
         THREE WAYS TO LOG
    ════════════════════════════════════════════ -->
    <section class="three-ways" id="three-ways">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">The Nubo Ecosystem</p>
          <h2>Tap as it happens.<br/>Talk to catch up.</h2>
          <p class="section-sub">Two moments, both covered. Log it the second it happens, or fill in what you missed an hour later. Whatever fits the moment. Everything lands in one timeline.</p>
        </div>

        <div class="ways-grid">
          <div class="way-card reveal">
            <div class="way-card-image">
              <img src="/images/nubo-instant-tracker-900.webp" alt="Hand pressing the Nubo instant tracker beside a sleeping baby" width="900" height="900" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Tap the device</h3>
              <p>The fastest log there is. No phone, no unlock, no opening anything. Press a button on Nubo and the activity is logged. One-handed, eyes closed, in the dark, or in broad daylight with the baby in your arms.</p>
              <span class="way-best">Best for: the absolute fastest log, hands full, phone locked or across the room</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-1">
            <div class="way-card-image">
              <img src="/images/appscreens/02_voicelogging.webp" alt="Nubo app voice logging screen for adding baby activity updates by speaking" width="642" height="1389" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Say it on your phone</h3>
              <p>Forgot to log earlier? Just say it naturally. &ldquo;Baby slept at 1 and woke up 10 minutes ago.&rdquo; Nubo understands ordinary speech, including times and relative phrases, then files the event at the right timestamp.</p>
              <span class="way-best">Best for: catching up on what already happened, voice notes for the pediatrician</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-2">
            <div class="way-card-image">
              <img src="/images/nubo-app-screens.webp" srcset="/images/nubo-app-screens-720.webp 720w, /images/nubo-app-screens.webp 1280w" sizes="(max-width: 720px) 92vw, (max-width: 1120px) 32vw, 360px" alt="Nubo app home screen showing colorful one-tap quick log cards for sleep, nursing, formula, pumping, and diaper" width="640" height="400" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Tap a card in the app</h3>
              <p>If your phone is already in your hand, the app's home screen has a colorful one-touch card for every routine event. Sleep, nursing, formula, pumping, diaper. Each card shows a live &ldquo;ago&rdquo; timer. One tap and it's logged.</p>
              <span class="way-best">Best for: when the phone is already open, scrubbing through the day's timeline</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-2">
            <div class="way-card-image">
              <img src="/images/nubo-alexa-echo-show.webp" srcset="/images/nubo-alexa-echo-show-720.webp 720w, /images/nubo-alexa-echo-show.webp 1280w" sizes="(max-width: 720px) 92vw, (max-width: 1120px) 32vw, 360px" alt="Nubo baby tracker dashboard displayed on an Amazon Echo Show" width="640" height="400" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Ask Alexa</h3>
              <p>&ldquo;Alexa, tell Newborn tracker I breast fed baby for half an hour.&rdquo; Natural language logging from across the room when your hands are full.</p>
              <span class="way-best">Best for: bottle prep, hands full, multitasking</span>
              <a href="/alexa/" class="text-link">See Alexa logging &rarr;</a>
            </div>
          </div>
        </div>

        <p class="ways-convergence reveal">Everything feeds into the same timeline. Nothing gets lost. Every caregiver sees the same data.</p>
        <p class="section-route reveal"><a href="/how-it-works/" class="text-link">See how the ecosystem works &rarr;</a></p>
      </div>
    </section>


    <AttentionLine lead="Built to support caregiving, not compete with it." />


    <!-- ════════════════════════════════════════════
         MEET NUBO (DEVICE)
    ════════════════════════════════════════════ -->
    <section class="meet-nubo" id="features">
      <div class="container meet-inner">
        <div class="meet-image reveal">
          <img
            src="/images/nubo-oneclick.webp"
            alt="Close-up of a finger pressing the sleep button on Nubo for one touch logging"
            width="740"
            height="554"
          />
        </div>
        <div class="meet-text reveal reveal-delay-1">
          <p class="overline">The Device</p>
          <h2>
            Like a light switch<br/>
            for baby tracking.
          </h2>
          <p class="meet-description meet-description-lead">
            A simple tap. Done.
          </p>
          <p class="meet-description">
            Nubo is a physical tracker built for the moments your phone can't reach.
            Press a button to log feeds, sleep, pee, and poop. It stores everything
            and syncs to the app when your phone is nearby.
          </p>
          <p class="meet-description">
            Use it one-handed, half-asleep, in the dark. Get back to your baby.
          </p>
          <p class="meet-description">
            A button needs no translation. Whoever is helping with the baby, a partner, a grandparent, a nanny, can log the same way you do. No app to learn, no language to read.
          </p>
          <a href="/device/" class="text-link">View the device page &rarr;</a>
        </div>
      </div>

      <div class="container meet-videos reveal">
        <div class="video-grid">
          <a href="https://www.youtube.com/watch?v=NH5-ECtIpzw" target="_blank" rel="noopener noreferrer" class="video-thumb">
            <img src="/images/nubo-instant-tracker-900.webp" alt="Unboxing the Nubo baby tracker" width="480" height="270" loading="lazy" decoding="async" />
            <span class="video-play" aria-hidden="true"></span>
            <span class="video-label">Watch Nubo unboxing</span>
          </a>
          <a href="https://www.youtube.com/watch?v=2XT00mDc2-U" target="_blank" rel="noopener noreferrer" class="video-thumb">
            <img src="/images/nubo-oneclick.webp" alt="Setting up the Nubo baby tracker" width="480" height="270" loading="lazy" decoding="async" />
            <span class="video-play" aria-hidden="true"></span>
            <span class="video-label">Watch Nubo setup</span>
          </a>
          <a href="https://www.youtube.com/watch?v=RyiNBesv804" target="_blank" rel="noopener noreferrer" class="video-thumb">
            <img src="/images/nubo-app-screens-720.webp" alt="Using Nubo to track baby activities and review in the app" width="480" height="270" loading="lazy" decoding="async" />
            <span class="video-play" aria-hidden="true"></span>
            <span class="video-label">Watch tracking demo</span>
          </a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         CAREGIVERS
    ════════════════════════════════════════════ -->
    <section class="caregivers" id="caregivers">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Nubo for Everyone</p>
          <h2>Unlimited caregivers.<br/>Always free.</h2>
          <p class="section-sub">Mom, dad, grandparents, nanny. Invite anyone with a QR code and turn everyone helping into one caregiving team across iOS and Android. Everyone sees the same end-to-end encrypted timeline in real time. No per-seat fees, no &ldquo;did you feed the baby?&rdquo; texts.</p>
        </div>

        <div class="caregivers-banner reveal">
          <img src="/images/caregiver-hub.webp" sizes="(max-width: 768px) 92vw, 970px" alt="Nubo device syncing baby tracking data with multiple caregiver phones" width="970" height="600" loading="lazy" decoding="async"/>
        </div>
        <p class="section-route reveal"><a href="/caregivers/" class="text-link">See caregiver sync &rarr;</a></p>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         REVIEWS
    ════════════════════════════════════════════ -->
    <section class="reviews" id="reviews">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Real Reviews</p>
          <h2>Parents who've<br/>been there.</h2>
        </div>

        <div class="reviews-aggregates reveal">
          <div class="reviews-aggregate">
            <span class="agg-stars" aria-label="4.2 out of 5 stars">★★★★☆</span>
            <span class="agg-text">4.2 stars on Amazon</span>
          </div>
          <a href={appStoreURL} target="_blank" rel="noopener noreferrer" class="reviews-aggregate reviews-aggregate-link">
            <span class="agg-stars" aria-label="App Store rating">★★★★★</span>
            <span class="agg-text">Loved on the App Store</span>
          </a>
        </div>

        <div class="reviews-grid">
          <blockquote class="review reveal">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;I tried three baby-tracker apps before this. All felt like spreadsheets with pastel icons. <strong>Nubo is the first one I can use half-asleep.</strong>&rdquo;</p>
            <footer><strong>Kiran K.</strong> &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-1">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;So much easier to tag team with our baby. If one of us has been out, the other can just <strong>glance at the app and see what's been going on.</strong>&rdquo;</p>
            <footer><strong>Devi</strong> &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-2">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;Our preemie needed exact intake tracking for the NICU follow-up. <strong>We exported the data and the pediatrician was impressed</strong> by how complete it was.&rdquo;</p>
            <footer><strong>Priya M.</strong> &middot; Austin, TX &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-3">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;My husband, my mom, and I all use Nubo. <strong>Nobody has to ask &lsquo;when did the baby eat last?&rsquo; anymore.</strong> That alone is worth it.&rdquo;</p>
            <footer><strong>Jessica R.</strong> &middot; Portland, OR &middot; Verified Purchase</footer>
          </blockquote>
        </div>

        <div class="reviews-link reveal">
          <a href="https://www.amazon.com/product-reviews/B0CJLNBG4P" target="_blank" rel="noopener noreferrer">
            Read all reviews on Amazon &rarr;
          </a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PRIVACY
    ════════════════════════════════════════════ -->
    <section class="privacy" id="privacy">
      <div class="container privacy-inner">
        <div class="privacy-text reveal">
          <p class="overline">Built for Your Privacy</p>
          <h2>Your baby's data<br/>stays yours.</h2>
          <p class="privacy-summary">Logs stay on your phone, voice runs on your phone, backups use your iCloud or Google Drive, caregiver sharing is encrypted.</p>
          <a href="/privacy/" class="text-link">Read the privacy overview &rarr;</a>
        </div>
        <div class="privacy-visual reveal reveal-delay-1">
          <img src="/images/privacy-shield.webp" alt="Nubo app interface showing privacy-first data widgets and encrypted sharing" width="600" height="405" />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PRICING
    ════════════════════════════════════════════ -->
    <section class="pricing" id="pricing">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Pricing</p>
          <h2>Simple pricing.<br/>Start free.</h2>
          <p class="section-sub">Pick the path that fits your household now. The full pricing page has the feature details, caregiver math, and Premium rules.</p>
        </div>

        <div class="pricing-trust-strip reveal" aria-label="Nubo purchase reassurance">
          <span>4.2 stars on Amazon</span>
          <span>No subscription required</span>
          <span>Private by design</span>
          <span>Free shipping with Prime</span>
          <span>30-day returns through Amazon</span>
        </div>

        <div class="pricing-grid pricing-grid-teaser">
          <article class="pricing-card pricing-teaser-card reveal">
            <div class="pricing-card-header">
              <h3>Free app</h3>
              <div class="pricing-price"><span class="pricing-amount">$0</span></div>
              <p class="pricing-tagline">Best when your phone is already in hand and you want a complete tracker without a paywall.</p>
            </div>
            <ul class="pricing-features pricing-features-short">
              <li>Feeds, sleep, diapers, growth, vaccines, allergens, and notes</li>
              <li>Unlimited caregivers and sync</li>
              <li>Voice catch-up for missed logs</li>
            </ul>
            <div class="pricing-card-footer">
              <a href="/app/" class="btn-ghost">Explore the app</a>
            </div>
          </article>

          <article class="pricing-card pricing-card-featured pricing-teaser-card reveal reveal-delay-1">
            <div class="pricing-badge">App upgrade</div>
            <div class="pricing-card-header">
              <h3>Premium</h3>
              <div class="pricing-price"><span class="pricing-amount">$39.99</span><span class="pricing-period">/year</span></div>
              <p class="pricing-tagline">Best for app-first families who want reminders, exports, Alexa, Live Activities, and private pumping.</p>
            </div>
            <ul class="pricing-features pricing-features-short">
              <li>Premium for the purchasing store account</li>
              <li>Pumping is not in the shared log</li>
              <li>Separate caregiver accounts may need Premium</li>
            </ul>
            <div class="pricing-card-footer">
              <a href="/pricing/" class="btn-primary">Compare Premium</a>
            </div>
          </article>

          <article class="pricing-card pricing-card-device pricing-teaser-card reveal reveal-delay-2">
            <div class="pricing-badge pricing-badge-device">Fastest</div>
            <div class="pricing-card-header">
              <h3>Nubo Device</h3>
              <div class="pricing-price"><span class="pricing-amount">$89.99</span></div>
              <p class="pricing-tagline">Best for nighttime feeds, hands-full moments, and households with nannies, grandparents, or daycare.</p>
            </div>
            <ul class="pricing-features pricing-features-short">
              <li>1-second, screen-free logging</li>
              <li>Premium for every caregiver who uses it</li>
              <li>Can pay back quickly in multi-caregiver households</li>
            </ul>
            <div class="pricing-card-footer">
              <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy on Amazon</a>
            </div>
          </article>
        </div>

        <p class="pricing-note reveal"><a href="/pricing/" class="text-link">See the full pricing guide &rarr;</a></p>

      </div>
    </section>


    <!-- ════════════════════════════════════════════
         FOUNDER
    ════════════════════════════════════════════ -->
    <section class="founder" id="founder">
      <div class="container">
        <div class="founder-inner reveal">
          <p class="overline">Created by a Mom, for Parents</p>
          <blockquote>
            <p>&ldquo;Nubo was born from the chaos of early motherhood. I was exhausted, overwhelmed, and constantly dropping the ball on tracking feeds and diapers. So I built what I wished existed: something so simple you could use it with your eyes closed. Because parenting is hard, but the moments that matter shouldn't be&nbsp;lost.&rdquo;</p>
          </blockquote>
          <p class="founder-name">Divya, Founder of Nubo</p>
          <p class="founder-sub">Mom. Engineer.</p>
          <a href="/about/" class="text-link founder-link">Read the Nubo story &rarr;</a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         FINAL CTA
    ════════════════════════════════════════════ -->
    <AttentionLine variant="kicker" lead="Track the moment. Stay with the baby." />

    <section class="final-cta" id="buy">
      <div class="container final-cta-inner reveal">
        <h2>Start free.<br/>Upgrade when it matters.</h2>
        <p class="final-price-frame">Premium is about 11 cents a day.</p>
        <p class="final-sub">The app is free. Premium is $39.99/year for reminders, exports, Alexa, private pumping, Live Activities, and advanced views. Add the $89.99 device when one-second logging matters.</p>

        <a href="/pricing/" class="btn-primary btn-lg">
          Choose your setup
        </a>

        <div class="final-trust-badges">
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Private by design
          </span>
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Private pumping included
          </span>
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Device ships with Prime
          </span>
        </div>

        <p class="final-urgency">At about 11 cents a day, Premium is the simplest upgrade when the full app starts saving you time.</p>

        <div class="store-badges">
          <p class="store-label">Get the free Nubo app and Alexa skill</p>
          <div class="store-links">
            <a href={appStoreURL} target="_blank" rel="noopener noreferrer">
              <img src="/images/appstore-badge.webp" alt="Download on the App Store" width="160" height="56" />
            </a>
            <a href={playStoreURL} target="_blank" rel="noopener noreferrer">
              <img src="/images/playstore-badge.webp" alt="Get it on Google Play" width="160" height="56" />
            </a>
