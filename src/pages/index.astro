    -->


    <!-- ════════════════════════════════════════════
         PRICING
    ════════════════════════════════════════════ -->
    <section class="pricing" id="pricing">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Pricing</p>
          <h2>Simple pricing.<br/>Start free.</h2>
          <p class="section-sub">Core baby tracking is free forever. No ads, no time limits, no credit card.</p>
        </div>

        <div class="pricing-grid">

          <!-- FREE TIER -->
          <div class="pricing-card reveal">
            <div class="pricing-card-header">
              <h3>Free</h3>
              <div class="pricing-price">
                <span class="pricing-amount">$0</span>
              </div>
              <p class="pricing-tagline">Free forever. No catch.</p>
            </div>
            <ul class="pricing-features">
              <li>Sleep, feeding &amp; diaper tracking</li>
              <li>Notes, charts &amp; manual alarms</li>
              <li>Fenton preemie and WHO growth tracking</li>
              <li>Immunization tracking</li>
              <li>Health measurements &amp; medications</li>
              <li>Activity tracking (tummy time, bath, more)</li>
              <li>CDC Milestone tracking</li>
              <li>What To Expect age-specific guidance</li>
              <li>One touch quick logging</li>
              <li>Unlimited child profiles</li>
              <li>Unlimited caregivers &amp; sync</li>
              <li>Unlimited cloud backup &amp; restore</li>
              <li>Offline mode, full functionality</li>
              <li>End-to-end encryption &amp; privacy first</li>
              <li class="pricing-gift">Includes 7-day free Premium trial</li>
            </ul>
            <div class="pricing-card-footer">
              <a href={appStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">
                Download Free
              </a>
            </div>
          </div>

          <!-- PREMIUM -->
          <div class="pricing-card pricing-card-featured reveal reveal-delay-1">
            <div class="pricing-badge">Most Popular</div>
            <div class="pricing-card-header">
              <h3>Premium</h3>
