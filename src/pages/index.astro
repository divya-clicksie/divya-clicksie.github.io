---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AttentionLine from '../components/AttentionLine.astro';

const title = 'Nubo Baby Tracker | One-Tap Baby Tracker for Night Feeds';
const description = 'The one-tap baby tracker for night feeds, hands-full moments, and multi-caregiver households. Use the device, free app, voice catch-up, and Alexa in one shared baby timeline.';

const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';
const alexaURL = 'https://www.amazon.com/Clicksie-LLC-Nubo-Baby-Tracker/dp/B0FJ2N8XKB';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": "Nubo Baby Activity Tracker",
      "alternateName": "One-tap baby tracker",
      "description": "The one-tap baby tracker for night feeds, hands-full moments, and multi-caregiver households. Nubo combines a physical device, in-app one-tap and voice logging, an Alexa skill, and a companion app for logging feedings, sleep, and diapers.",
      "image": "https://www.nubotracker.com/images/nubo-instant-tracker.webp",
      "url": "https://www.nubotracker.com/",
      "category": "Baby activity tracker",
      "brand": {
        "@type": "Brand",
        "name": "Nubo",
        "sameAs": [
          "https://www.instagram.com/nubo_baby_tracker",
          "https://www.youtube.com/@NuboBabyTracker"
        ]
      },
      "offers": {
        "@type": "Offer",
        "url": amazonURL,
        "priceCurrency": "USD",
        "price": "89.99",
        "availability": "https://schema.org/InStock"
      }
    },
    {
      "@type": "MobileApplication",
      "name": "Nubo Baby Tracker",
      "operatingSystem": "iOS, Android",
      "applicationCategory": "HealthApplication",
      "description": "Free baby tracker app with one-tap quick logging and on-device voice logging. Track feeds, sleep, diapers, growth (WHO and Fenton), vaccines, allergens, and milestones. Unlimited caregivers, unlimited cloud backup, full offline mode.",
      "image": "https://www.nubotracker.com/images/nubo-instant-tracker.webp",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "installUrl": appStoreURL,
      "downloadUrl": [appStoreURL, playStoreURL]
    }
  ]
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>

    <!-- ════════════════════════════════════════════
         HERO
    ════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-glow"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="overline">One-tap baby tracker</p>
          <h1>
            Baby tracking that keeps up
            <span class="hero-accent">when newborn life gets messy.</span>
          </h1>
          <p class="hero-sub">
            Track feeds, sleep, and diapers with the free app, voice catch-up, or the one-tap device, the fastest way to log.
          </p>
          <div class="hero-actions">
            <a href="/device/" class="btn-primary">
              See one-tap device
            </a>
            <a href="/app/#app-downloads" class="btn-ghost">
              Download free app
            </a>
          </div>
        </div>
        <div class="hero-image">
          <img
            src="/images/hero.webp"
            sizes="(max-width: 768px) 72vw, (max-width: 900px) 88vw, 42vw"
            alt="Nubo baby tracker beside a caregiver holding a newborn"
            width="782"
            height="878"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PAIN POINT
    ════════════════════════════════════════════ -->
    <section class="pain-point">
      <div class="container">
        <div class="pain-inner reveal">
          <p class="overline">Sound familiar?</p>
          <h2>Tracking should not be one more thing to remember.</h2>
          <div class="problem-grid">
            <article><h3>Night feeds</h3><p>Log without waking yourself with a bright screen.</p></article>
            <article><h3>Hands full</h3><p>Tap the matching event button while the care moment is happening.</p></article>
            <article><h3>Handoffs</h3><p>Everyone sees the same day without check-in texts.</p></article>
          </div>
        </div>
      </div>
    </section>


    <AttentionLine lead="Built to support caregiving, not compete with it." />

    <!-- ════════════════════════════════════════════
         THREE WAYS TO LOG
    ════════════════════════════════════════════ -->
    <section class="three-ways" id="three-ways">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">How the one-tap baby tracker works</p>
          <h2>One baby timeline. Log however the moment allows.</h2>
          <p class="section-sub">Tap the device, speak a sentence, tap a card, or ask Alexa. Everything lands in one timeline that caregivers can trust.</p>
          <p class="ways-intro-note">Nubo does not ask every caregiver to build the same habit. The fastest method changes by moment, so the timeline accepts them all.</p>
        </div>

        <div class="ways-grid">
          <div class="way-card reveal">
            <div class="way-card-image">
              <img src="/images/nubo-instant-tracker-900.webp" alt="Hand pressing the Nubo instant tracker beside a sleeping baby" width="900" height="900" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Tap the device</h3>
              <p>Tap the matching button for feeds, sleep, pee, or poop when your phone is locked, across the room, or too bright for 3 a.m.</p>
              <span class="way-best">Best for: night feeds, hands full, phone across the room</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-1">
            <div class="way-card-image">
              <img src="/images/appscreens/02_voicelogging.webp" alt="Nubo app voice logging screen for adding baby activity updates by speaking" width="642" height="1389" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Say it on your phone</h3>
              <p>Remembered later? Say what happened in plain English and Nubo files the structured log at the right time.</p>
              <span class="way-best">Best for: missed logs, fuzzy times, quick catch-up</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-2">
            <div class="way-card-image">
              <img src="/images/nubo-app-screens.webp" srcset="/images/nubo-app-screens-720.webp 720w, /images/nubo-app-screens.webp 1280w" sizes="(max-width: 720px) 92vw, (max-width: 1120px) 32vw, 360px" alt="Nubo app home screen showing colorful one-tap quick log cards for sleep, nursing, formula, pumping, and diaper" width="640" height="400" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Tap a card in the app</h3>
              <p>Use colorful quick cards when your phone is already open and you want to log, review, or edit the day.</p>
              <span class="way-best">Best for: app-first tracking, reviewing the day</span>
            </div>
          </div>

          <div class="way-card reveal reveal-delay-2">
            <div class="way-card-image">
              <img src="/images/nubo-alexa-echo-show.webp" srcset="/images/nubo-alexa-echo-show-720.webp 720w, /images/nubo-alexa-echo-show.webp 1280w" sizes="(max-width: 720px) 92vw, (max-width: 1120px) 32vw, 360px" alt="Nubo baby tracker dashboard displayed on an Amazon Echo Show" width="640" height="400" loading="lazy" decoding="async"/>
            </div>
            <div class="way-card-body">
              <h3>Ask Alexa</h3>
              <p>Log from across the room when your hands are busy and the phone is not where the care is happening.</p>
              <span class="way-best">Best for: kitchens, nurseries, shared rooms</span>
              <a href="/alexa/" class="text-link">See Alexa logging &rarr;</a>
            </div>
          </div>
        </div>

        <p class="ways-convergence reveal">One record comes out: synced across caregivers, ready for handoffs, and not rebuilt from memory.</p>
        <p class="section-route reveal"><a href="/compare/" class="text-link">Compare setup options &rarr;</a></p>
      </div>
    </section>


    <section class="setup-choice" id="choose">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Choose your setup</p>
          <h2>Start free. Add speed when your phone becomes the bottleneck.</h2>
          <p class="section-sub">Pick the path that fits today. You can start with the app, add Premium for advanced tools, or buy the device for the fastest logging.</p>
        </div>
        <div class="setup-grid">
          <article class="setup-card reveal">
            <span class="setup-label">Free app</span>
            <h3>Start tracking today.</h3>
            <p>Quick logs, voice catch-up, caregiver sync, offline use, and private storage without ads, a credit card, or a trial countdown.</p>
            <a href="/app/#app-downloads" class="btn-primary">Download free app</a>
          </article>
          <article class="setup-card reveal reveal-delay-1">
            <span class="setup-label">Premium</span>
            <h3>Add advanced app tools.</h3>
            <p>Use reminders, exports, Alexa, Live Activities, Care Vault, private pumping, and advanced views when your app workflow needs more.</p>
            <a href="/pricing/#plans" class="btn-ghost">Compare Premium</a>
          </article>
          <article class="setup-card setup-card-device reveal reveal-delay-2">
            <span class="setup-label">Nubo device</span>
            <h3>One tap when opening the phone fails.</h3>
            <p>Best for night feeds, hands-full changes, nannies, grandparents, and households where every active caregiver needs Premium.</p>
            <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy device</a>
          </article>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         CAREGIVERS
    ════════════════════════════════════════════ -->
    <section class="caregivers" id="caregivers">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Nubo for Everyone</p>
          <h2>Unlimited caregivers.<br/>Always free.</h2>
          <p class="section-sub">Invite a partner, grandparent, nanny, or family helper with a QR code. Everyone sees the same encrypted timeline across iOS and Android.</p>
        </div>

        <div class="caregivers-banner reveal">
          <img src="/images/caregiver-hub.webp" sizes="(max-width: 768px) 92vw, 970px" alt="Nubo device syncing baby tracking data with multiple caregiver phones" width="970" height="600" loading="lazy" decoding="async"/>
        </div>
        <p class="section-route reveal"><a href="/caregivers/" class="text-link">See caregiver sync &rarr;</a></p>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PRIVACY
    ════════════════════════════════════════════ -->
    <section class="privacy" id="privacy">
      <div class="container privacy-inner">
        <div class="privacy-text reveal">
          <p class="overline">Built for Your Privacy</p>
          <h2>Your baby's data<br/>stays yours.</h2>
          <ul class="privacy-list">
            <li>No ads and no selling baby data.</li>
            <li>In-app voice catch-up runs on your phone.</li>
            <li>Backups use your iCloud or Google Drive.</li>
            <li>Caregiver sharing is encrypted between invited people.</li>
          </ul>
          <a href="/privacy/" class="text-link">Read the privacy overview &rarr;</a>
        </div>
        <div class="privacy-visual reveal reveal-delay-1">
          <img src="/images/privacy-shield.webp" alt="Nubo app interface showing privacy-first data widgets and encrypted sharing" width="600" height="405" />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PRICING
    ════════════════════════════════════════════ -->
    <section class="pricing" id="pricing">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Pricing</p>
          <h2>Simple pricing.<br/>Start free.</h2>
          <p class="section-sub">Pick the path that fits your household now. The full pricing page has the feature details, caregiver math, and Premium rules.</p>
        </div>

        <div class="pricing-trust-strip reveal" aria-label="Nubo purchase reassurance">
          <span>4.2 stars on Amazon</span>
          <span>No subscription required</span>
          <span>Private by design</span>
          <span>Free shipping with Prime</span>
          <span>30-day returns through Amazon</span>
        </div>

        <div class="pricing-grid pricing-grid-teaser">
          <article class="pricing-card pricing-teaser-card reveal">
            <div class="pricing-card-header">
              <h3>Free app</h3>
              <div class="pricing-price"><span class="pricing-amount">$0</span></div>
              <p class="pricing-tagline">Best when your phone is already in hand and you want a complete tracker without a paywall.</p>
            </div>
            <ul class="pricing-features pricing-features-short">
              <li>Feeds, sleep, diapers, growth, vaccines, allergens, and notes</li>
              <li>Unlimited caregivers and sync</li>
              <li>Voice catch-up for missed logs</li>
            </ul>
            <div class="pricing-card-footer">
              <a href="/app/" class="btn-ghost">Explore the app</a>
            </div>
          </article>

          <article class="pricing-card pricing-card-featured pricing-teaser-card reveal reveal-delay-1">
            <div class="pricing-badge">App upgrade</div>
            <div class="pricing-card-header">
              <h3>Premium</h3>
              <div class="pricing-price"><span class="pricing-amount">$39.99</span><span class="pricing-period">/year</span></div>
              <p class="pricing-tagline">Best for app-first families who want reminders, exports, Alexa, Live Activities, and private pumping.</p>
            </div>
            <ul class="pricing-features pricing-features-short">
              <li>Premium for the purchasing store account</li>
              <li>Pumping is not in the shared log</li>
              <li>Separate caregiver accounts may need Premium</li>
            </ul>
            <div class="pricing-card-footer">
              <a href="/pricing/" class="btn-primary">Compare Premium</a>
            </div>
          </article>

          <article class="pricing-card pricing-card-device pricing-teaser-card reveal reveal-delay-2">
            <div class="pricing-badge pricing-badge-device">Fastest</div>
            <div class="pricing-card-header">
              <h3>Nubo Device</h3>
              <div class="pricing-price"><span class="pricing-amount">$89.99</span></div>
              <p class="pricing-tagline">Best for nighttime feeds, hands-full moments, and households with nannies, grandparents, or daycare.</p>
            </div>
            <ul class="pricing-features pricing-features-short">
              <li>1-second, screen-free logging</li>
              <li>Premium for every caregiver who uses it</li>
              <li>Can pay back quickly in multi-caregiver households</li>
            </ul>
            <div class="pricing-card-footer">
              <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy on Amazon</a>
            </div>
          </article>
        </div>

        <p class="pricing-note reveal"><a href="/pricing/" class="text-link">See the full pricing guide &rarr;</a></p>

      </div>
    </section>


    <!-- ════════════════════════════════════════════
         REVIEWS
    ════════════════════════════════════════════ -->
    <section class="reviews" id="reviews">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Real-life use cases</p>
          <h2>Built for newborn chaos.</h2>
        </div>

        <div class="reviews-grid">
          <article class="review reveal"><h3>Half-asleep logging</h3><p>Tap the device during a night feed, then go back to soothing the baby instead of opening an app.</p></article>
          <article class="review reveal reveal-delay-1"><h3>Caregiver handoffs</h3><p>Partners, grandparents, and nannies can work from one shared timeline instead of a stream of texts.</p></article>
          <article class="review reveal reveal-delay-2"><h3>Pediatrician prep</h3><p>Keep feeds, diapers, sleep, medicine, and growth organized when a visit needs clearer history.</p></article>
          <article class="review reveal reveal-delay-3"><h3>Phone-light care</h3><p>Use the app when it helps, the device buttons when the phone gets in the way, and voice when you remember later.</p></article>
        </div>

        <div class="reviews-link reveal">
          <a href="https://www.amazon.com/product-reviews/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas" target="_blank" rel="noopener noreferrer">
            Read all reviews on Amazon &rarr;
          </a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         FOUNDER
    ════════════════════════════════════════════ -->
    <section class="founder" id="founder">
      <div class="container">
        <div class="founder-inner reveal">
          <p class="overline">Created by a Mom, for Parents</p>
          <blockquote>
            <p>&ldquo;Nubo was born from the chaos of early motherhood. I was exhausted, overwhelmed, and constantly dropping the ball on tracking feeds and diapers. So I built what I wished existed: something so simple you could use it with your eyes closed. Because parenting is hard, but the moments that matter shouldn't be&nbsp;lost.&rdquo;</p>
          </blockquote>
          <p class="founder-name">Divya, Founder of Nubo</p>
          <p class="founder-sub">Mom. Engineer.</p>
          <a href="/about/" class="text-link founder-link">Read the Nubo story &rarr;</a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         FINAL CTA
    ════════════════════════════════════════════ -->
    <AttentionLine variant="kicker" lead="Track the moment. Stay with the baby." />

    <section class="final-cta" id="buy">
      <div class="container final-cta-inner reveal">
        <h2>Start free.<br/>Upgrade when it matters.</h2>
        <p class="final-price-frame">Premium is about 11 cents a day.</p>
        <p class="final-sub">The app is free. Premium is $39.99/year for reminders, exports, Alexa, private pumping, Live Activities, and advanced views. Add the $89.99 device when one-second logging matters.</p>

        <div class="final-actions">
          <a href="/app/#app-downloads" class="btn-primary btn-lg">Download free app</a>
          <a href={amazonURL} class="btn-ghost btn-lg" target="_blank" rel="noopener noreferrer">Buy device</a>
          <a href="/pricing/" class="text-link">Compare setups &rarr;</a>
        </div>

        <div class="final-trust-badges">
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Private by design
          </span>
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Private pumping included
          </span>
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Device ships with Prime
          </span>
        </div>

        <p class="final-urgency">At about 11 cents a day, Premium is the simplest upgrade when the full app starts saving you time.</p>

        <div class="store-badges">
          <p class="store-label">Get the free Nubo app and Alexa skill</p>
          <div class="store-links">
            <a href={appStoreURL} target="_blank" rel="noopener noreferrer">
              <img src="/images/appstore-badge.webp" alt="Download on the App Store" width="160" height="56" />
            </a>
            <a href={playStoreURL} target="_blank" rel="noopener noreferrer">
              <img src="/images/playstore-badge.webp" alt="Get it on Google Play" width="160" height="56" />
            </a>
            <a href={alexaURL} target="_blank" rel="noopener noreferrer" class="alexa-badge-link">
              <img src="/images/just-ask-alexa-badge.webp" alt="Just Ask Alexa" width="250" height="122" />
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     HERO
  ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(170deg, #f0fafa 0%, #fff 40%, var(--color-bg-warm) 100%);
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 70%;
    height: 80%;
    background: radial-gradient(ellipse, rgba(19, 188, 195, 0.08) 0%, transparent 70%);
    filter: blur(60px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 2rem;
    padding-top: calc(72px + 3rem);
    padding-bottom: 3rem;
  }

  .hero-content h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: 0;
    color: var(--color-text);
  }

  .hero-accent {
    color: var(--color-brand);
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 460px;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image img {
    max-height: min(85vh, 600px);
    width: auto;
    object-fit: contain;
    border-radius: var(--radius-xl);
    filter: drop-shadow(0 20px 60px rgba(19, 188, 195, 0.12));
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 0;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1.25rem;
      padding-top: 88px;
      padding-bottom: 2.5rem;
      min-height: auto;
    }
    .hero-content h1 { font-size: clamp(2rem, 10vw, 2.65rem); }
    .hero-accent { display: block; }
    .hero-sub { margin: 1rem auto 0; font-size: 1rem; line-height: 1.65; }
    .hero-actions { justify-content: center; }
    .hero-image { order: -1; }
    .hero-image img { max-height: 24vh; max-width: 72vw; }
  }


  /* ═══════════════════════════════════════════
     PAIN POINT
  ═══════════════════════════════════════════ */
  .pain-point {
    padding: 5rem 0;
    background: #fff;
  }

  .pain-inner {
    max-width: 980px;
    margin: 0 auto;
    text-align: center;
  }

  .pain-inner h2 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.12;
    margin: 0.75rem auto 2rem;
    max-width: 680px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .problem-grid article {
    padding: 1.5rem;
    border: 1px solid #e8e8e8;
    border-radius: var(--radius-xl);
    background: var(--color-bg-soft);
    text-align: left;
  }

  .problem-grid h3 {
    font-size: 1.0625rem;
    margin-bottom: 0.5rem;
  }

  .problem-grid p {
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  .setup-choice {
    padding: 6rem 0;
    background: var(--color-bg-soft);
  }

  .setup-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .setup-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    border: 1px solid #e8e8e8;
