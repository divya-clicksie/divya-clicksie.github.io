                <td>Works at 3 AM in the dark</td>
                <td class="compare-highlight">✓</td>
                <td>Bright screen</td>
                <td>✗</td>
              </tr>
              <tr>
                <td>Caregiver sync</td>
                <td class="compare-highlight">Automatic</td>
                <td>Manual sharing</td>
                <td>✗</td>
              </tr>
              <tr>
                <td>Battery anxiety</td>
                <td class="compare-highlight">Months</td>
                <td>Daily charge</td>
                <td>N/A</td>
              </tr>
              <tr>
                <td>Insights &amp; patterns</td>
                <td class="compare-highlight">✓</td>
