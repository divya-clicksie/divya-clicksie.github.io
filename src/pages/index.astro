---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Nubo | One-Touch Baby Activity Tracker | Track Feedings, Sleep & Diapers';
const description = 'Nubo is the fastest baby tracker. One tap to log feedings, sleep, and diapers without reaching for your phone. Syncs to a free app with Nubo Premium included for every caregiver.';

const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Nubo Baby Activity Tracker",
  "description": "One-touch baby activity tracker and companion app for logging feedings, sleep, and diapers.",
  "image": "https://www.nubotracker.com/images/hero.webp",
  "brand": { "@type": "Brand", "name": "nubo" },
  "offers": {
    "@type": "Offer",
    "url": amazonURL,
    "priceCurrency": "USD",
    "price": "89.99",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.2",
    "reviewCount": "32"
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>

    <!-- ════════════════════════════════════════════
         HERO
    ════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-glow"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-content reveal">
          <h1>
            Nobody remembers at 3&nbsp;a.m.
            <span class="hero-accent">Nubo does.</span>
          </h1>
          <p class="hero-sub">
            Track feeds, sleep, and diapers with one tap, and keep every caregiver instantly in sync.
          </p>
          <div class="hero-actions">
            <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">
              Buy on Amazon
            </a>
            <a href="#how-it-works" class="btn-ghost">See how it works</a>
          </div>
          <div class="hero-trust">
            <span>No phone needed</span>
            <span class="trust-sep">&middot;</span>
            <span>Free app</span>
            <span class="trust-sep">&middot;</span>
            <span>Premium included</span>
          </div>
        </div>
        <div class="hero-image reveal reveal-delay-2">
          <img
            src="/images/hero.webp"
            alt="A mother tenderly holding her newborn, with Nubo baby tracker in the foreground"
            width="760"
            height="862"
            loading="eager"
          />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PAIN POINT
    ════════════════════════════════════════════ -->
    <section class="pain-point">
      <div class="container">
        <div class="pain-inner reveal">
          <p class="overline">Sound familiar?</p>
          <p class="pain-text">
            You're breastfeeding in the dark. The baby finally latched. You need to log it.
            But your phone is across the room. Or dead. Or you'd have to unlock it, open the app,
            find the right screen... so you just don't.
          </p>
          <p class="pain-relief">Nubo fixes that. One tap. Eyes on baby. Done.</p>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         LIGHT SWITCH CALLOUT
    ════════════════════════════════════════════ -->
    <section class="light-switch">
      <div class="container">
        <p class="light-switch-text reveal">
          Like a <strong>light&nbsp;switch</strong> for baby tracking.
        </p>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         MEET NUBO
    ════════════════════════════════════════════ -->
    <section class="meet-nubo" id="meet-nubo">
      <div class="container meet-inner">
        <div class="meet-image reveal">
          <img
            src="/images/nubo-frontal.webp"
            alt="Nubo baby tracker, white device with teal edges showing feeding, sleep, and diaper buttons"
            width="380"
            height="800"
          />
        </div>
        <div class="meet-text reveal reveal-delay-1">
          <p class="overline">Meet Nubo</p>
          <h2>
            The fastest way to track<br/>
            your baby's day.
          </h2>
          <p class="meet-description">
            Nubo is a physical tracker designed for the chaos of newborn life.
            Clear buttons for every activity. No screens, no apps, no fumbling.
            Just one tap. Even at 3&nbsp;AM, even with one hand, even when your brain is mush.
          </p>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         HOW IT WORKS
    ════════════════════════════════════════════ -->
    <section class="how-it-works" id="how-it-works">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">How It Works</p>
          <h2>Set up in 2 minutes.<br/>Use for months.</h2>
        </div>

        <div class="steps">
          <div class="step reveal">
            <div class="step-num">1</div>
            <h3>Pair with your phone</h3>
            <p>Download the free Nubo app, connect via Bluetooth, and invite caregivers. That's the only time you need your phone.</p>
          </div>
          <div class="step reveal reveal-delay-1">
            <div class="step-num">2</div>
            <h3>Tap to log activities</h3>
            <p>Feeding, sleep, diaper. Press the button on Nubo. One touch. The device stores everything and syncs when your phone is nearby.</p>
          </div>
          <div class="step reveal reveal-delay-2">
            <div class="step-num">3</div>
            <h3>See patterns in the app</h3>
            <p>Feeding trends, sleep duration, AI-powered insights. Walk into the pediatrician's office prepared instead of guessing.</p>
          </div>
        </div>


      </div>
    </section>


    <!-- ════════════════════════════════════════════
         ONE TOUCH
    ════════════════════════════════════════════ -->
    <section class="one-touch" id="features">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">One Touch Logging</p>
          <h2>Log activities<br/>without reaching<br/>for your phone.</h2>
        </div>
        <div class="one-touch-image reveal">
          <img
            src="/images/nubo-oneclick.webp"
            alt="Close-up of a finger pressing the sleep button on Nubo for one touch logging"
            width="740"
            height="554"
          />
        </div>
        <p class="one-touch-caption reveal">
          Clear, intuitive buttons for feeding, sleeping, pee, and poop.
          Press once. Nubo confirms with a gentle light. Done. Get back to your baby.
        </p>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         FEATURES
    ════════════════════════════════════════════ -->
    <section class="features-section">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Thoughtfully Designed</p>
          <h2>Built for real life<br/>with a newborn.</h2>
        </div>

        <div class="feature-grid">
          <div class="feature-card feature-wide reveal">
            <div class="feature-card-image">
              <img src="/images/feature-magnetic.webp" alt="Nubo magnetically docked to a refrigerator" width="740" height="554" />
            </div>
            <div class="feature-card-text">
              <h3>Magnetic docking</h3>
              <p>Snap Nubo to your fridge, clip it to the crib, or toss it in the diaper bag. Magnetic stickers included. It goes wherever your baby goes.</p>
            </div>
          </div>

          <div class="feature-card reveal">
            <div class="feature-card-image">
              <img src="/images/feature-water.webp" alt="Nubo covered in water droplets, water resistant" width="740" height="554" />
            </div>
            <div class="feature-card-text">
              <h3>Water &amp; spill resistant</h3>
              <p>Life with a baby is messy. Nubo can handle it. Just wipe clean and keep going.</p>
            </div>
          </div>

          <div class="feature-card reveal reveal-delay-1">
            <div class="feature-card-image">
              <img src="/images/feature-battery.webp" alt="Calendars showing months of battery life" width="740" height="554" />
            </div>
            <div class="feature-card-text">
              <h3>Months of battery</h3>
              <p>Coin cell battery. No charging cables. An extra battery in the box eliminates anxiety.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         CAREGIVERS
    ════════════════════════════════════════════ -->
    <section class="caregivers" id="caregivers">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Nubo for Everyone</p>
          <h2>Every caregiver.<br/>One page. Always.</h2>
          <p class="section-sub">Mom, dad, grandparents, nanny. Everyone sees the same data. No more &ldquo;did you feed the baby?&rdquo; texts.</p>
        </div>

        <div class="caregivers-grid">
          <div class="caregiver-card reveal">
            <div class="caregiver-img">
              <img src="/images/audience-parents.png" alt="Parents viewing their Nubo app to understand their newborn's routine" width="600" height="432" />
            </div>
            <div class="caregiver-text">
              <h3>For parents</h3>
              <p>Understand your newborn's routine. See patterns in feeding, sleep, and diapers to plan your day with confidence.</p>
            </div>
          </div>

          <div class="caregiver-card reveal reveal-delay-1">
            <div class="caregiver-img">
              <img src="/images/audience-grandparents.png" alt="Grandparents holding their grandchild with the Nubo collaboration screen on phone" width="600" height="432" />
            </div>
            <div class="caregiver-text">
              <h3>For grandparents &amp; nannies</h3>
              <p>No apps to learn. No logins to remember. Just press the button when something happens. The parents see it instantly.</p>
            </div>
          </div>

          <div class="caregiver-card reveal reveal-delay-2">
            <div class="caregiver-img">
              <img src="/images/audience-doctors.png" alt="Pediatrician reviewing baby's feeding and sleep data on phone during a checkup" width="600" height="432" />
            </div>
            <div class="caregiver-text">
              <h3>For pediatricians</h3>
              <p>Parents arrive with accurate, timestamped data. Feeding volumes, sleep duration, output. No more guesswork.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         REVIEWS
    ════════════════════════════════════════════ -->
    <section class="reviews" id="reviews">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Real Reviews</p>
          <h2>Parents who've<br/>been there.</h2>
        </div>

        <div class="reviews-aggregate reveal">
          <span class="agg-stars" aria-label="4.2 out of 5 stars">★★★★☆</span>
          <span class="agg-text">4.2 stars on Amazon</span>
        </div>

        <div class="reviews-grid">
          <blockquote class="review reveal">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;I tried three baby-tracker apps before this. All felt like spreadsheets with pastel icons. <strong>Nubo is the first one I can use half-asleep.</strong>&rdquo;</p>
            <footer><strong>Kiran K.</strong> &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-1">
            <div class="review-stars">★★★★☆</div>
            <p>&ldquo;Our nanny often missed logging activities on time. We mounted Nubo next to the nursery doorway. <strong>It's been a game-changer.</strong>&rdquo;</p>
            <footer><strong>HB</strong> &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-2">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;So much easier to tag team with our baby. If one of us has been out, the other can just <strong>glance at the app and see what's been going on.</strong>&rdquo;</p>
            <footer><strong>Devi</strong> &middot; Verified Purchase</footer>
          </blockquote>

          <blockquote class="review reveal reveal-delay-3">
            <div class="review-stars">★★★★★</div>
            <p>&ldquo;You can log sleep, diapers, and feeding within a second. <strong>A luxury product that feels premium</strong> in both design and function.&rdquo;</p>
            <footer><strong>Ilya K.</strong> &middot; Verified Purchase</footer>
          </blockquote>
        </div>

        <div class="reviews-link reveal">
          <a href="https://www.amazon.com/product-reviews/B0CJLNBG4P" target="_blank" rel="noopener noreferrer">
            Read all reviews on Amazon &rarr;
          </a>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         PRIVACY
    ════════════════════════════════════════════ -->
    <section class="privacy" id="privacy">
      <div class="container privacy-inner">
        <div class="privacy-text reveal">
          <p class="overline">Privacy by Design</p>
          <h2>Your baby's data<br/>stays yours.</h2>
          <ul class="privacy-list">
            <li>No account required to use device or app</li>
            <li>Data stays on your phone, not our servers</li>
            <li>End-to-end encrypted sharing</li>
            <li>Backup to your own iCloud or Google Drive</li>
            <li>We never sell or share your information</li>
          </ul>
          <a href="/privacy-policy/" class="text-link">Read our privacy policy &rarr;</a>
        </div>
        <div class="privacy-visual reveal reveal-delay-1">
          <img src="/images/privacy-shield.png" alt="Nubo app interface showing privacy-first data widgets and encrypted sharing" width="600" height="405" />
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         GIFT
    ════════════════════════════════════════════ -->
    <section class="gift" id="gift">
      <div class="container gift-inner">
        <div class="gift-image reveal">
          <img
            src="/images/nubo-gift.webp"
            alt="Nubo beautifully packaged as a gift in a premium white box with the device inside"
            width="600"
            height="480"
          />
        </div>
        <div class="gift-text reveal reveal-delay-1">
          <p class="overline">Baby Shower Favorite</p>
          <h2>The gift every new parent actually uses.</h2>
          <p class="gift-desc">
            Skip the onesies. Give the gift of time, sanity, and confidence.
            Nubo comes beautifully packaged and ready to unwrap. No wrapping needed.
          </p>
          <a href={amazonURL} class="btn-primary gift-cta" target="_blank" rel="noopener noreferrer">
            Gift it on Amazon
          </a>
          <div class="gift-box">
            <h3>What's in the box</h3>
            <ul>
              <li>Nubo device (with battery)</li>
              <li>Milk volume sticker</li>
              <li>Magnetic mount sticker</li>
              <li>Extra battery</li>
              <li>Lanyard</li>
              <li>Setup &amp; user guides</li>
            </ul>
          </div>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         COMPARE
    ════════════════════════════════════════════ -->
    <section class="compare">
      <div class="container">
        <div class="section-intro reveal">
          <p class="overline">Why Nubo?</p>
          <h2>Nubo vs. the alternatives.</h2>
        </div>
        <div class="compare-table-wrap reveal">
          <table class="compare-table">
            <thead>
              <tr>
                <th></th>
                <th class="compare-highlight">Nubo</th>
                <th>Phone Apps</th>
                <th>Pen &amp; Paper</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Log an activity</td>
                <td class="compare-highlight">1 second</td>
                <td>30+ seconds</td>
                <td>15+ seconds</td>
              </tr>
              <tr>
                <td>Hands-free logging</td>
                <td class="compare-highlight">✓</td>
                <td>✗</td>
                <td>✗</td>
              </tr>
              <tr>
                <td>Works at 3 AM in the dark</td>
                <td class="compare-highlight">✓</td>
                <td>Bright screen</td>
                <td>✗</td>
              </tr>
              <tr>
                <td>Caregiver sync</td>
                <td class="compare-highlight">Automatic</td>
                <td>Manual sharing</td>
                <td>✗</td>
              </tr>
              <tr>
                <td>Battery anxiety</td>
                <td class="compare-highlight">Months</td>
                <td>Daily charge</td>
                <td>N/A</td>
              </tr>
              <tr>
                <td>Insights &amp; patterns</td>
                <td class="compare-highlight">✓</td>
                <td>✓</td>
                <td>✗</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         FOUNDER
    ════════════════════════════════════════════ -->
    <section class="founder">
      <div class="container">
        <div class="founder-inner reveal">
          <p class="overline">Created by a Mom, for Parents</p>
          <blockquote>
            <p>&ldquo;Nubo was born from the chaos of early motherhood. I was exhausted, overwhelmed, and constantly dropping the ball on tracking feeds and diapers. So I built what I wished existed: something so simple you could use it with your eyes closed. Because parenting is hard, but the moments that matter shouldn't be&nbsp;lost.&rdquo;</p>
          </blockquote>
          <p class="founder-name">Divya, Founder of Nubo</p>
          <p class="founder-sub">Mom. Engineer. Sleep-deprived inventor.</p>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════
         FINAL CTA
    ════════════════════════════════════════════ -->
    <section class="final-cta" id="buy">
      <div class="container final-cta-inner reveal">
        <h2>Ready to track<br/>smarter?</h2>
        <p class="final-price-frame">Less than $1 a day for the first 3 months.</p>
        <p class="final-sub">$89.99 on Amazon &middot; Free companion app &middot; Free shipping with Prime</p>

        <a href={amazonURL} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">
          Buy on Amazon
        </a>

        <div class="final-trust-badges">
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Private by design
          </span>
          <span class="trust-badge">
            <span class="trust-badge-icon">★</span>
            4.2 stars on Amazon
          </span>
          <span class="trust-badge">
            <span class="trust-badge-icon">✓</span>
            Free shipping with Prime
          </span>
        </div>

        <p class="final-urgency">Most parents buy in the third trimester. Don't wait until the chaos starts.</p>

        <div class="store-badges">
          <p class="store-label">Download the free companion app</p>
          <div class="store-links">
            <a href={appStoreURL} target="_blank" rel="noopener noreferrer">
              <img src="/images/appstore-badge.png" alt="Download on the App Store" width="160" height="56" />
            </a>
            <a href={playStoreURL} target="_blank" rel="noopener noreferrer">
              <img src="/images/playstore-badge.png" alt="Get it on Google Play" width="160" height="56" />
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>


<style>
  /* ═══════════════════════════════════════════
     HERO
  ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(170deg, #f0fafa 0%, #fff 40%, var(--color-bg-warm) 100%);
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 70%;
    height: 80%;
    background: radial-gradient(ellipse, rgba(19, 188, 195, 0.08) 0%, transparent 70%);
    filter: blur(60px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 2rem;
    padding-top: calc(72px + 3rem);
    padding-bottom: 3rem;
  }

  .hero-content h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .hero-accent {
    color: var(--color-brand);
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 460px;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-trust {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    flex-wrap: wrap;
  }

  .trust-sep {
    color: #ccc;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image img {
    max-height: min(85vh, 600px);
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 60px rgba(19, 188, 195, 0.12));
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 0;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding-top: 100px;
      padding-bottom: 3rem;
      min-height: auto;
    }
    .hero-accent { display: block; }
    .hero-sub { margin: 1rem auto 0; }
    .hero-actions { justify-content: center; }
    .hero-trust { justify-content: center; }
    .hero-image { order: -1; }
    .hero-image img { max-height: 50vh; }
  }


  /* ═══════════════════════════════════════════
     MEET NUBO
  ═══════════════════════════════════════════ */
  .meet-nubo {
    padding: 8rem 0;
    background: var(--color-bg-soft);
  }

  .meet-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 6rem;
    align-items: center;
  }

  .meet-image img {
    height: 520px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 30px 80px rgba(0, 0, 0, 0.08));
  }

  .meet-text .overline { }

  .meet-text h2 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .meet-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  .meet-description + .meet-description {
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .meet-nubo { padding: 5rem 0; }
    .meet-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }
    .meet-image { display: flex; justify-content: center; }
    .meet-image img { height: 360px; }
    .meet-description { margin-left: auto; margin-right: auto; }
  }


  /* ═══════════════════════════════════════════
     PAIN POINT
  ═══════════════════════════════════════════ */
  .pain-point {
