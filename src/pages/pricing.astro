---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpeedComparison from '../components/SpeedComparison.astro';
import CaregiverEconomics from '../components/CaregiverEconomics.astro';
import PremiumFollowsDevice from '../components/PremiumFollowsDevice.astro';

const title = 'Pricing | Nubo One-Tap Baby Tracker, Free App, and Premium';
const description = 'Choose the right one-tap baby tracker setup: free app, Premium, or the Nubo device for night feeds, hands-full moments, and multi-caregiver households.';

const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      name: title,
      description,
      url: 'https://www.nubotracker.com/pricing/',
      about: { '@type': 'Product', name: 'Nubo Baby Tracker' }
    },
    {
      '@type': 'Product',
      name: 'Nubo Baby Tracker Device',
      alternateName: ['One-tap baby tracker', 'Physical baby tracker device'],
      description: 'A one-tap baby tracker device for night feeds, hands-full moments, and multi-caregiver households.',
      image: 'https://www.nubotracker.com/images/nubo-instant-tracker.webp',
      sku: 'B0CJLNBG4P',
      brand: { '@type': 'Brand', name: 'Nubo' },
      offers: {
        '@type': 'Offer',
        name: 'Nubo Device',
        price: '89.99',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        itemCondition: 'https://schema.org/NewCondition',
        url: amazonURL
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.2',
        reviewCount: '32'
      }
    },
    {
      '@type': 'MobileApplication',
      name: 'Nubo Baby Tracker App',
      operatingSystem: 'iOS, Android',
      applicationCategory: 'HealthApplication',
      description: 'Free baby tracker app with one-tap quick logs, voice catch-up, caregiver sync, and private baby timeline tools.',
      offers: [
        { '@type': 'Offer', name: 'Nubo app Free', price: '0', priceCurrency: 'USD', url: appStoreURL },
        { '@type': 'Offer', name: 'Nubo Premium', price: '39.99', priceCurrency: 'USD', url: appStoreURL }
      ],
      installUrl: [appStoreURL, playStoreURL],
      downloadUrl: [appStoreURL, playStoreURL]
    },
    {
      '@type': 'OfferCatalog',
      name: 'Nubo setup options',
      itemListElement: [
        { '@type': 'Offer', itemOffered: { '@type': 'MobileApplication', name: 'Nubo free app' }, price: '0', priceCurrency: 'USD', url: appStoreURL },
        { '@type': 'Offer', itemOffered: { '@type': 'SoftwareApplication', name: 'Nubo Premium' }, price: '39.99', priceCurrency: 'USD', url: appStoreURL },
        { '@type': 'Offer', itemOffered: { '@type': 'Product', name: 'Nubo Device' }, price: '89.99', priceCurrency: 'USD', url: amazonURL }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="page-hero pricing-hero">
      <div class="container">
        <p class="overline">One-tap baby tracker pricing</p>
        <h1>Start free. Upgrade when time, sleep, or caregivers make it worth it.</h1>
        <p class="page-hero-sub">Three paths count: install the free app, upgrade to Premium, or buy the device once for one-second logging and Premium for every caregiver who uses it.</p>
        <div class="hero-actions-inline">
          <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy on Amazon</a>
          <a href={appStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Download free</a>
          <a href={playStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Google Play</a>
        </div>
      </div>
    </section>

    <section class="decision-section">
      <div class="container">
        <div class="section-intro">
          <p class="overline">Decision guide</p>
          <h2>Choose by household, not by feature list.</h2>
        </div>
        <div class="decision-grid">
          <article><h3>Solo parent, phone usually in hand</h3><p>Start with the free app. It covers the daily basics without a paywall.</p><a href={appStoreURL} target="_blank" rel="noopener noreferrer">Download free</a></article>
          <article><h3>Two parents, mostly app-first</h3><p>Free works for shared basics. Premium adds advanced tools for the purchasing store account, and the device adds speed when the phone is not open.</p><a href="#plans">Compare plans</a></article>
          <article class="decision-featured"><h3>Multi-caregiver household</h3><p>Nanny, grandparents on separate plans, postpartum doula, or daycare staff? The device is the cleanest value.</p><a href={amazonURL} target="_blank" rel="noopener noreferrer">Buy the device</a></article>
          <article><h3>App user ready for advanced features</h3><p>Premium adds reminders, exports, Alexa, Live Activities, advanced metrics, Premium modes, and a private pumping tracker.</p><a href={appStoreURL} target="_blank" rel="noopener noreferrer">Try Premium</a></article>
          <article><h3>Buying a gift</h3><p>The device is the easiest gift to understand: one button, one-time purchase, useful from the first week.</p><a href="/gift/">Gift guide</a></article>
        </div>
      </div>
    </section>

    <section class="plans-section" id="plans">
      <div class="container">
        <div class="trust-strip" aria-label="Nubo purchase reassurance">
          <span>4.2 stars on Amazon</span>
          <span>No subscription required</span>
          <span>Private by design</span>
          <span>Free shipping with Prime</span>
          <span>30-day returns through Amazon</span>
        </div>

        <div class="pricing-grid">
          <article class="pricing-card">
            <h3>Free</h3>
            <p class="price">$0</p>
            <p class="tagline">A complete baby tracker for parents who want to start today.</p>
            <ul>
              <li>Sleep, feeding, diaper, growth, vaccine, allergen, medication, and milestone tracking</li>
              <li>Unlimited caregivers across iOS and Android, child profiles, cloud backup, and event logs</li>
              <li>Unlimited in-app voice logging and quick-log cards</li>
              <li>Offline mode and local-first private storage</li>
            </ul>
            <a href={appStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Download free</a>
          </article>

          <article class="pricing-card pricing-card-featured">
            <div class="badge">App upgrade</div>
            <h3>Premium</h3>
            <p class="price">$39.99<span>/year</span></p>
            <p class="tagline">For app-first families who want advanced tools without hardware.</p>
            <ul>
              <li>Everything in Free</li>
              <li>Auto Reminders, Alexa logging, Live Activities, and CSV export</li>
              <li>Private pumping tracker for milk output. Not in the shared log, not in caregiver sync.</li>
              <li>Advanced growth metrics, Allergen SafeStart, Smart Averages, and Premium themes</li>
              <li>Premium is managed by the App Store or Google Play account that buys it. Caregivers on separate store accounts usually need their own Premium, or the device can cover everyone who uses it.</li>
            </ul>
            <a href={appStoreURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Download and try Premium</a>
          </article>

          <article class="pricing-card pricing-card-device">
            <div class="badge badge-dark">Best value for caregivers</div>
            <h3>Nubo Device</h3>
            <p class="price">$89.99</p>
            <p class="tagline">Premium for every caregiver who uses it.</p>
            <ul>
              <li>Any caregiver phone that connects to your Nubo gets 30 days of Premium, even across separate App Store or Google Play accounts</li>
              <li>Shared tracking stays end-to-end encrypted across Apple and Google ecosystems</li>
              <li>Active caregivers stay on Premium continuously with no per-seat fees to manage</li>
              <li>Physical one-touch logging for feeds, sleep, pee, and poop</li>
              <li>Bluetooth sync, magnetic mount, lanyard, and months of battery life</li>
            </ul>
            <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy on Amazon</a>
          </article>
        </div>
        <p class="return-note">Free shipping with Prime · 30-day returns through Amazon</p>
      </div>
    </section>

    <SpeedComparison compact />
    <CaregiverEconomics />
    <PremiumFollowsDevice />

    <section class="second-baby-section">
      <div class="container second-baby-inner">
        <div>
          <p class="overline">Long-term value</p>
          <h2>Planning for another baby changes the math.</h2>
          <p>If your family may use a tracker through more than one newborn stage, the device is the path that keeps coming back into service.</p>
        </div>
        <div class="second-baby-grid">
          <article><h3>Free app</h3><p>Useful now and later. Each child can have a separate profile, and the core timeline keeps working without a subscription.</p></article>
          <article><h3>Premium app</h3><p>Good for advanced tools when one primary app account needs Premium and you prefer an app-first setup.</p></article>
          <article><h3>Nubo device</h3><p>Best long-term value when you want hardware that can support future babies and active caregivers across separate accounts.</p></article>
        </div>
      </div>
    </section>

    <section class="faq-band">
      <div class="container">
        <div class="section-intro">
          <p class="overline">Pricing FAQ</p>
          <h2>Clear answers before you choose.</h2>
        </div>
        <div class="faq-grid">
          <article><h3>Does the device require a Premium subscription?</h3><p>No. The device is the Premium-grant mechanism. It keeps working with the free app, and every phone that connects to it gets Premium for 30 days.</p></article>
          <article><h3>How does the device give caregivers Premium?</h3><p>When a caregiver phone pairs for the first time or syncs new logs as it walks by, that phone gets Premium for 30 days. Each subsequent sync resets the window.</p></article>
          <article><h3>What happens if a caregiver only visits occasionally?</h3><p>Premium stays active for 30 days after the last sync. If it lapses, it reactivates the next time that phone syncs with the device.</p></article>
          <article><h3>Does Premium work if my partner buys the device?</h3><p>Yes. The device grants Premium to whatever phone connects to it. It does not care who paid or whose Apple or Google account is involved.</p></article>
          <article><h3>Can my partner use Nubo too?</h3><p>Yes. The free tier supports unlimited caregivers. Premium tools belong to the App Store or Google Play account that buys Premium, and the device can grant Premium to separate caregiver accounts when they use it.</p></article>
          <article><h3>Does Premium include a pumping tracker?</h3><p>Yes. Premium includes a private pumping tracker for milk output. Pumping data is not in the shared baby log, not in caregiver sync, and not visible to partners, nannies, grandparents, or other collaborators. Read how it works in the <a href="/blog/privacy/pumping-tracker-private-data/">pumping privacy guide</a>.</p></article>
          <article><h3>What happens to my data if I cancel Premium?</h3><p>Your data stays on your phone and the free tier keeps working. You do not lose your baby history.</p></article>
          <article><h3>What if I have a second baby?</h3><p>The app and device can keep working for future children. A one-time device purchase is especially strong for families planning beyond one baby.</p></article>
          <article><h3>Can I return the device?</h3><p>Nubo is sold on Amazon, so returns follow Amazon's standard return policy.</p></article>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .pricing-hero .hero-actions-inline { justify-content: center; margin-top: 2rem; }
  .hero-actions-inline { display: flex; gap: 1rem; flex-wrap: wrap; }
  .decision-section, .plans-section, .second-baby-section, .faq-band { padding: 6rem 0; }
  .decision-section, .faq-band { background: #fff; }
  .plans-section, .second-baby-section { background: var(--color-bg-soft); }
  .decision-grid, .pricing-grid, .second-baby-grid, .faq-grid { display: grid; gap: 1.5rem; }
  .decision-grid { grid-template-columns: repeat(5, 1fr); }
  .pricing-grid { grid-template-columns: repeat(3, 1fr); align-items: stretch; }
  .second-baby-grid { grid-template-columns: repeat(3, 1fr); }
  .faq-grid { grid-template-columns: repeat(2, 1fr); }
  .decision-grid article, .pricing-card, .second-baby-grid article, .faq-grid article { background: #fff; border: 1px solid #e8e8e8; border-radius: var(--radius-xl); padding: 1.75rem; }
  .decision-featured, .pricing-card-device { border: 2px solid #1d1d1f !important; box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08); }
  .pricing-card-featured { border: 2px solid var(--color-brand); box-shadow: 0 12px 36px rgba(19, 188, 195, 0.12); }
  .decision-grid h3, .pricing-card h3, .second-baby-grid h3, .faq-grid h3 { font-size: 1.125rem; line-height: 1.25; margin-bottom: 0.75rem; }
  .decision-grid p, .pricing-card li, .second-baby-inner p, .faq-grid p { color: var(--color-text-secondary); line-height: 1.7; }
  .second-baby-inner { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 4rem; align-items: start; }
  .second-baby-inner h2 { font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.12; margin-bottom: 1rem; }
  .decision-grid a { display: inline-flex; margin-top: 1rem; color: var(--color-brand-dark); font-weight: 700; }
  .trust-strip { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-bottom: 2rem; }
  .trust-strip span { background: #fff; color: var(--color-text); border-radius: 999px; padding: 0.625rem 1rem; font-size: 0.875rem; font-weight: 700; }
  .pricing-card { position: relative; display: flex; flex-direction: column; }
  .pricing-card .badge { position: absolute; top: 0; right: 1.5rem; background: var(--color-brand); color: #fff; border-radius: 0 0 10px 10px; padding: 0.375rem 0.875rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; }
  .pricing-card .badge-dark { background: #1d1d1f; }
  .price { font-size: 2.75rem; font-weight: 700; line-height: 1; margin: 0.5rem 0; }
  .price span { font-size: 1rem; color: var(--color-text-secondary); }
  .tagline { color: var(--color-text-secondary); line-height: 1.6; min-height: 5rem; }
  .pricing-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; margin: 1.5rem 0; flex: 1; }
  .pricing-card li { position: relative; padding-left: 1.5rem; }
  .pricing-card li::before { content: '✓'; position: absolute; left: 0; color: var(--color-brand); font-weight: 700; }
  .pricing-card .btn-primary, .pricing-card .btn-ghost { width: 100%; }
  .return-note { margin-top: 1.5rem; text-align: center; color: var(--color-text-secondary); font-weight: 700; }
  @media (max-width: 1120px) { .decision-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 980px) { .pricing-grid, .faq-grid { grid-template-columns: 1fr 1fr; } .second-baby-inner { grid-template-columns: 1fr; gap: 2.5rem; } }
  @media (max-width: 680px) { .decision-section, .plans-section, .second-baby-section, .faq-band { padding: 4rem 0; } .decision-grid, .pricing-grid, .second-baby-grid, .faq-grid { grid-template-columns: 1fr; } .tagline { min-height: 0; } }
</style>