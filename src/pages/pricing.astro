---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Pricing | Nubo Free App, Premium, and Device';
const description = 'Compare Nubo pricing: free baby tracker app, Premium app upgrade for $39.99/year, and the Nubo physical tracker device for $89.99.';

const amazonURL = 'https://www.amazon.com/nubo-Newborn-Activity-Tracker-Color/dp/B0CJLNBG4P?maas=maas_adg_465D5CB69C73F660B7AD38831E2D680B_afap_abs&ref_=aa_maas&tag=maas';
const appStoreURL = 'https://apps.apple.com/us/app/nubo-baby-tracker/id1667461158';
const playStoreURL = 'https://play.google.com/store/apps/details?id=com.clicksie.nuboapp';

const appFeatures = [
  'Routine tracking for feeds, sleep, diapers, medicine, growth, vaccines, allergens, milestones, and notes',
  'Quick-log cards for fast app entries',
  'In-app voice catch-up when you need to add several events at once',
  'Unlimited caregivers on the shared baby timeline',
  'Cross-platform caregiver sync for iPhone and Android',
  'Offline mode when the connection is spotty',
  'Cloud backup with your own iCloud or Google Drive account',
  'Multiple child profiles',
  'No ads, no credit card, and no trial countdown'
];

const premiumFeatures = [
  'Everything in the free app',
  'Smarter reminders for feeds, bottles, naps, and care events',
  'Sleep Sounds, including calming shush sounds for settling',
  'Care Vault for standing handoff details',
  'CSV exports',
  'Alexa logging',
  'Live Activities',
  'Private pumping tracker',
  'Advanced views for patterns and totals'
];

const deviceFeatures = [
  'Everything in the free app',
  'Physical one-tap tracker for screen-free logging',
  'Dedicated buttons for bottle feeds, nursing, sleep, pee, and poop',
  'Bluetooth sync with the Nubo app',
  'Works with iPhone and Android caregivers through the app',
  'Refreshed 30-day Premium window for each phone that syncs with the device',
  'Premium app tools during the active device window: reminders, Sleep Sounds, Care Vault, exports, Alexa, Live Activities, private pumping, and advanced views',
  'Magnetic mount for a crib rail, nightstand, or changing area',
  'Lanyard for keeping the tracker close',
  'Battery included, designed for months of everyday use'
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      name: title,
      description,
      url: 'https://www.nubotracker.com/pricing/',
      about: { '@type': 'Thing', name: 'Nubo Baby Tracker' }
    },
    {
      '@type': 'Product',
      name: 'Nubo Baby Tracker Device',
      alternateName: ['One-tap baby tracker', 'Physical baby tracker device', 'Screen-free baby tracker'],
      description: 'A physical one-tap baby tracker device for screen-free logging, caregiver handoffs, and shared baby routines.',
      image: 'https://www.nubotracker.com/images/nubo-instant-tracker.webp',
      sku: 'B0CJLNBG4P',
      brand: { '@type': 'Brand', name: 'Nubo' },
      offers: {
        '@type': 'Offer',
        name: 'Nubo Device',
        price: '89.99',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        itemCondition: 'https://schema.org/NewCondition',
        url: amazonURL
      }
    },
    {
      '@type': 'MobileApplication',
      name: 'Nubo Baby Tracker App',
      operatingSystem: 'iOS, Android',
      applicationCategory: 'HealthApplication',
      description: 'Free baby tracker app with quick logs, voice catch-up, caregiver sync, offline mode, and private baby timeline tools.',
      offers: [
        { '@type': 'Offer', name: 'Nubo free app', price: '0', priceCurrency: 'USD', url: appStoreURL },
        { '@type': 'Offer', name: 'Nubo Premium', price: '39.99', priceCurrency: 'USD', url: appStoreURL }
      ],
      installUrl: [appStoreURL, playStoreURL],
      downloadUrl: [appStoreURL, playStoreURL]
    },
    {
      '@type': 'OfferCatalog',
      name: 'Nubo pricing options',
      itemListElement: [
        {
          '@type': 'Offer',
          name: 'Free app',
          price: '0',
          priceCurrency: 'USD',
          url: appStoreURL,
          itemOffered: { '@type': 'MobileApplication', name: 'Nubo Baby Tracker App' }
        },
        {
          '@type': 'Offer',
          name: 'Premium app upgrade',
          price: '39.99',
          priceCurrency: 'USD',
          url: appStoreURL,
          itemOffered: { '@type': 'SoftwareApplication', name: 'Nubo Premium' }
        },
        {
          '@type': 'Offer',
          name: 'Nubo device',
          price: '89.99',
          priceCurrency: 'USD',
          url: amazonURL,
          itemOffered: { '@type': 'Product', name: 'Nubo Baby Tracker Device' }
        }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="page-hero pricing-hero">
      <div class="container">
        <p class="overline">Nubo pricing</p>
        <h1>Choose your Nubo plan.</h1>
        <p class="page-hero-sub">Start with the free app, upgrade to Premium for advanced app tools, or buy the physical tracker device for one-tap logging.</p>
        <div class="hero-price-row" aria-label="Nubo pricing summary">
          <span>Free app: $0</span>
          <span>Premium: $39.99/year</span>
          <span>Device: $89.99</span>
        </div>
      </div>
    </section>

    <section class="plans-section" id="plans">
      <div class="container">
        <div class="pricing-grid">
          <article class="pricing-card">
            <div class="plan-heading">
              <p class="plan-label">App</p>
              <h2>Free</h2>
              <p class="price">$0</p>
              <p class="tagline">Core baby tracking for iPhone, Android, and shared caregivers.</p>
            </div>
            <ul class="feature-list" aria-label="Free app features">
              {appFeatures.map((feature) => <li>{feature}</li>)}
            </ul>
            <div class="card-actions">
              <a href={appStoreURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Download on the App Store</a>
              <a href={playStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Get it on Google Play</a>
            </div>
          </article>

          <article class="pricing-card pricing-card-featured">
            <div class="plan-badge">App upgrade</div>
            <div class="plan-heading">
              <p class="plan-label">Premium</p>
              <h2>Premium</h2>
              <p class="price">$39.99<span>/year</span></p>
              <p class="tagline">Advanced app tools for families who want reminders, exports, deeper views, and cleaner handoffs.</p>
            </div>
            <ul class="feature-list" aria-label="Premium features">
              {premiumFeatures.map((feature) => <li>{feature}</li>)}
            </ul>
            <div class="card-actions">
              <a href={appStoreURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Upgrade in the iPhone app</a>
              <a href={playStoreURL} class="btn-ghost" target="_blank" rel="noopener noreferrer">Upgrade in the Android app</a>
            </div>
          </article>

          <article class="pricing-card pricing-card-device">
            <div class="plan-badge plan-badge-dark">Physical tracker</div>
            <div class="plan-heading">
              <p class="plan-label">Device</p>
              <h2>Nubo Device</h2>
              <p class="price">$89.99</p>
              <p class="tagline">A one-time Amazon purchase for screen-free logging and caregiver-friendly routines.</p>
            </div>
            <ul class="feature-list" aria-label="Nubo device features">
              {deviceFeatures.map((feature) => <li>{feature}</li>)}
            </ul>
            <div class="card-actions">
              <a href={amazonURL} class="btn-primary" target="_blank" rel="noopener noreferrer">Buy on Amazon</a>
            </div>
          </article>
        </div>

        <p class="pricing-note">Premium prices are handled by the App Store or Google Play. Device price, shipping, availability, and returns follow the current Amazon listing.</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .pricing-hero {
    padding-bottom: 4rem;
  }

  .pricing-hero .container {
    max-width: 980px;
  }

  .pricing-hero h1,
  .pricing-hero .page-hero-sub {
    overflow-wrap: anywhere;
  }

  .hero-price-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-price-row span {
    max-width: 100%;
    border: 1px solid #e8e8e8;
    border-radius: 999px;
    background: #fff;
    color: var(--color-text);
    padding: 0.7rem 1rem;
    font-weight: 800;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .plans-section {
    padding: 4rem 0 6rem;
    background: var(--color-bg-soft);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-width: 0;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    box-shadow: 0 16px 38px rgba(31, 41, 55, 0.06);
    overflow: hidden;
  }

  .pricing-card-featured {
    border: 2px solid var(--color-brand);
    box-shadow: 0 18px 44px rgba(19, 188, 195, 0.14);
  }

  .pricing-card-device {
    border: 2px solid #1d1d1f;
    box-shadow: 0 18px 44px rgba(31, 41, 55, 0.11);
  }

  .plan-badge {
    position: absolute;
    top: 0;
    right: 1.5rem;
    border-radius: 0 0 10px 10px;
    background: var(--color-brand);
    color: #fff;
    padding: 0.4rem 0.85rem;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .plan-badge-dark {
    background: #1d1d1f;
  }

  .plan-heading {
    padding-top: 0.45rem;
  }

  .plan-label {
    margin: 0 0 0.45rem;
    color: var(--color-brand-dark);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .pricing-card h2 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.1;
    overflow-wrap: anywhere;
  }

  .price {
    margin: 0.85rem 0 0.65rem;
    color: var(--color-text);
    font-size: clamp(2.4rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1;
    overflow-wrap: anywhere;
  }

  .price span {
    color: var(--color-text-secondary);
    font-size: 1rem;
    font-weight: 700;
  }

  .tagline {
    min-height: 5.4rem;
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .feature-list {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.85rem;
    list-style: none;
    margin: 1.6rem 0;
    padding: 0;
  }

  .feature-list li {
    position: relative;
    min-width: 0;
    padding-left: 1.55rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  .feature-list li::before {
    position: absolute;
    left: 0;
    top: 0.1rem;
    color: var(--color-brand-dark);
    font-weight: 900;
    content: '+';
  }

  .card-actions {
    display: grid;
    gap: 0.75rem;
    margin-top: auto;
  }

  .card-actions .btn-primary,
  .card-actions .btn-ghost {
    width: 100%;
    min-height: 3.1rem;
    padding-right: 1rem;
    padding-left: 1rem;
    text-align: center;
    white-space: normal;
  }

  .pricing-note {
    max-width: 820px;
    margin: 1.75rem auto 0;
    color: var(--color-text-secondary);
    font-weight: 700;
    line-height: 1.6;
    text-align: center;
  }

  @media (max-width: 1120px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 760px;
      margin: 0 auto;
    }

    .tagline {
      min-height: 0;
    }
  }

  @media (max-width: 680px) {
    .pricing-hero {
      padding-bottom: 3rem;
    }

    .pricing-hero h1 {
      max-width: 340px;
      margin-right: auto;
      margin-left: auto;
      font-size: clamp(2.15rem, 9vw, 2.6rem);
    }

    .pricing-hero .page-hero-sub {
      max-width: 340px;
      font-size: 1rem;
    }

    .plans-section {
      padding: 3rem 0 4rem;
    }

    .hero-price-row {
      justify-content: stretch;
    }

    .hero-price-row span {
      width: 100%;
      text-align: center;
    }

    .pricing-card {
      padding: 1.35rem;
    }

    .pricing-card h2 {
      font-size: 1.65rem;
    }

    .price {
      font-size: 2.65rem;
    }

    .plan-badge {
      position: static;
      align-self: flex-start;
      border-radius: 999px;
      margin-bottom: 1rem;
    }

    .plan-heading {
      padding-top: 0;
    }
  }
</style>
